<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/mainShellRoot"
    android:orientation="vertical"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_plan_canvas"
    android:fitsSystemWindows="false"
    app:statusBarBackground="?attr/mzBg">

    <LinearLayout
        android:id="@+id/drawerContentRoot"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:orientation="vertical">

        <androidx.appcompat.widget.Toolbar
            android:id="@+id/toolbar"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:minHeight="?attr/actionBarSize"
            android:background="@drawable/bg_toolbar"
            android:elevation="0dp"
            android:paddingStart="0dp"
            android:paddingEnd="0dp"
            app:contentInsetStart="0dp"
            app:contentInsetEnd="0dp"
            app:contentInsetStartWithNavigation="0dp"
            android:titleTextColor="?attr/mzNavHeaderText">

            <include layout="@layout/include_plan_toolbar_content" />
        </androidx.appcompat.widget.Toolbar>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:baselineAligned="false"
            android:orientation="horizontal"
            android:padding="16dp">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_marginEnd="12dp"
                android:layout_weight="0.3"
                android:background="@drawable/bg_tablet_surface"
                android:orientation="vertical"
                android:padding="14dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="8dp"
                    android:text="@string/plan_view_mode_label"
                    android:textColor="?attr/mzMuted"
                    android:textSize="12sp"
                    android:textStyle="bold" />

                <LinearLayout
                    android:id="@+id/layoutViewModesRow"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="16dp"
                    android:background="@drawable/bg_tablet_surface_soft"
                    android:orientation="horizontal"
                    android:padding="5dp">

                    <androidx.appcompat.widget.AppCompatButton
                        android:id="@+id/btnViewDay"
                        android:layout_width="0dp"
                        android:layout_height="44dp"
                        android:layout_marginEnd="5dp"
                        android:layout_weight="1"
                        android:background="@drawable/selector_mode_bg"
                        android:elevation="0dp"
                        android:stateListAnimator="@null"
                        android:text="@string/plan_view_day"
                        android:textAllCaps="false"
                        android:textColor="@color/selector_mode_text"
                        android:textSize="12sp"
                        android:textStyle="bold"
                        app:backgroundTint="@null" />

                    <androidx.appcompat.widget.AppCompatButton
                        android:id="@+id/btnViewWeek"
                        android:layout_width="0dp"
                        android:layout_height="44dp"
                        android:layout_marginEnd="5dp"
                        android:layout_weight="1"
                        android:background="@drawable/selector_mode_bg"
                        android:elevation="0dp"
                        android:stateListAnimator="@null"
                        android:text="@string/plan_view_week"
                        android:textAllCaps="false"
                        android:textColor="@color/selector_mode_text"
                        android:textSize="12sp"
                        android:textStyle="bold"
                        app:backgroundTint="@null" />

                    <androidx.appcompat.widget.AppCompatButton
                        android:id="@+id/btnViewMonth"
                        android:layout_width="0dp"
                        android:layout_height="44dp"
                        android:layout_weight="1"
                        android:background="@drawable/selector_mode_bg"
                        android:elevation="0dp"
                        android:stateListAnimator="@null"
                        android:text="@string/plan_view_month"
                        android:textAllCaps="false"
                        android:textColor="@color/selector_mode_text"
                        android:textSize="12sp"
                        android:textStyle="bold"
                        app:backgroundTint="@null" />
                </LinearLayout>
            </LinearLayout>

            <FrameLayout
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="0.7"
                android:background="@drawable/bg_tablet_surface"
                android:padding="10dp">

                <LinearLayout
                    android:id="@+id/planContentRoot"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:orientation="vertical">

                    <LinearLayout
                        android:id="@+id/layoutWeekHeadersFixed"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:background="@drawable/bg_plan_header"
                        android:orientation="horizontal"
                        android:paddingTop="10dp"
                        android:paddingBottom="10dp"
                        android:visibility="gone">

                        <View
                            android:layout_width="40dp"
                            android:layout_height="match_parent" />

                        <LinearLayout
                            android:id="@+id/layoutWeekHeadersRow"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="horizontal" />
                    </LinearLayout>

                    <LinearLayout
                        android:id="@+id/layoutMonthHeadersFixed"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:background="@drawable/bg_plan_header"
                        android:orientation="horizontal"
                        android:paddingTop="10dp"
                        android:paddingBottom="10dp"
                        android:visibility="gone" />

                    <ScrollView
                        android:id="@+id/scrollPlan"
                        android:layout_width="match_parent"
                        android:layout_height="0dp"
                        android:layout_weight="1"
                        android:fillViewport="true"
                        android:scrollbars="vertical">

                        <LinearLayout
                            android:id="@+id/planScrollContent"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="vertical">

                            <LinearLayout
                                android:id="@+id/layoutPlanRoot"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:orientation="horizontal">

                                <LinearLayout
                                    android:id="@+id/layoutTimeColumn"
                                    android:layout_width="40dp"
                                    android:layout_height="wrap_content"
                                    android:gravity="end"
                                    android:orientation="vertical"
                                    android:paddingEnd="6dp" />

                                <androidx.viewpager2.widget.ViewPager2
                                    android:id="@+id/planViewPager"
                                    android:layout_width="0dp"
                                    android:layout_height="wrap_content"
                                    android:layout_weight="1"
                                    android:overScrollMode="never" />
                            </LinearLayout>
                        </LinearLayout>
                    </ScrollView>
                </LinearLayout>

                <ProgressBar
                    android:id="@+id/planProgress"
                    style="?android:attr/progressBarStyleLarge"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center"
                    android:indeterminate="true"
                    android:visibility="gone" />

                <TextView
                    android:id="@+id/tvEmpty"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:gravity="center"
                    android:text="@string/plan_no_classes_in_range"
                    android:textColor="?attr/mzMuted"
                    android:textSize="14sp"
                    android:visibility="gone" />

                <com.google.android.material.floatingactionbutton.FloatingActionButton
                    android:id="@+id/fabAddEvent"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="bottom|end"
                    android:layout_margin="10dp"
                    android:contentDescription="@string/plan_custom_add_event"
                    android:src="@drawable/ic_plus"
                    android:visibility="gone"
                    app:backgroundTint="?attr/mzPrimary"
                    app:tint="@android:color/white" />
            </FrameLayout>
        </LinearLayout>
    </LinearLayout>
    <include layout="@layout/include_bottom_navigation" />
</LinearLayout>
