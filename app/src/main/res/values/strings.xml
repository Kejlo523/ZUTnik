    <string name="about_title">O aplikacji</string>

    <!-- About screen / nagłówek -->
    <string name="about_header_pill">ℹ️ Informacje o aplikacji</string>
    <string name="about_subtitle">
        Nieoficjalna aplikacja mobilna dla studentów ZUT, z planem zajęć, ocenami, informacjami o studiach i widżetem dziennym — bez reklam i śledzenia.
    </string>

    <!-- About: projekt i autor -->
    <string name="about_section_project_title">Projekt i autor</string>
    <string name="about_author_line">Autorem aplikacji jest Jędrzej Nowak.</string>
    <string name="about_project_description_1">
        mZUT v2 został stworzony jako nieoficjalna, lekka alternatywa do szybkiego podglądu planu, ocen i informacji o studiach na ZUT, bez konieczności przeklikiwania się przez ciężkie panele www.
    </string>
    <string name="about_project_description_2">
        Aplikacja wykorzystuje publicznie dostępne systemy i API uczelni, a dane logowania pozostają na Twoim urządzeniu.
    </string>

    <!-- About: kontakt i linki -->
    <string name="about_section_contact_title">Kontakt i linki</string>
    <string name="about_contact_email">E-mail: kejlo@endozero.pl</string>
    <string name="about_contact_website">Strona: endozero.pl</string>
    <string name="about_contact_app_website">Strona aplikacji: mzut.endozero.pl</string>
    <string name="about_contact_github">GitHub: https://github.com/Kejlo523/mzut-v2</string>

    <!-- About: prywatność -->
    <string name="about_section_privacy_title">Prywatność i dane</string>
    <string name="about_privacy_text_1">
        mZUT v2 nie korzysta z zewnętrznych systemów analityki (Google Analytics, Firebase Analytics itp.), nie wyświetla reklam oraz nie śledzi Twoich działań w aplikacji.
    </string>
    <string name="about_privacy_text_2">
        Dane logowania wykorzystywane są wyłącznie do uwierzytelnienia w systemach uczelni i przechowywane lokalnie na urządzeniu. Żadne dane nie są wysyłane na serwery autora aplikacji.
    </string>

    <!-- About: stopka -->
    <string name="about_footer_disclaimer">
        mZUT v2 jest projektem nieoficjalnym i nie jest aplikacją wydaną przez Zachodniopomorski Uniwersytet Technologiczny.
    </string>

