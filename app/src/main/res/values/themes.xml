<resources xmlns:tools="http://schemas.android.com/tools">

    <!-- Base Application Theme -->
    <style name="Base.Theme.MZUTv2" parent="Theme.MaterialComponents.DayNight.NoActionBar">
        <!-- Status Bar -->
        <item name="android:statusBarColor">@android:color/transparent</item>
        <item name="android:windowLightStatusBar">true</item>

        <!-- Navigation Bar -->
        <item name="android:navigationBarColor">@android:color/transparent</item>
        <item name="android:windowLightNavigationBar">true</item>

        <!-- No Title -->
        <item name="windowActionBar">false</item>
        <item name="android:windowActionBar">false</item>
        <item name="windowNoTitle">true</item>

        <!-- Splash -->
        <item name="android:windowSplashScreenBackground">?attr/mzBg</item>
        <item name="android:windowSplashScreenAnimatedIcon">@mipmap/ic_zut_logo</item>
        <item name="android:windowSplashScreenAnimationDuration">200</item>
        <item name="android:windowSplashScreenIconBackgroundColor">@android:color/transparent</item>
    </style>

    <!-- Default Theme (Light/Reference) uses colors.xml -->
    <style name="Theme.MZUTv2" parent="Base.Theme.MZUTv2">
        <item name="colorPrimary">@color/mz_primary</item>
        <item name="colorPrimaryVariant">@color/mz_primary_alt</item>
        <item name="colorOnPrimary">@color/mz_text</item>

        <item name="mzBg">@color/mz_bg</item>
        <item name="mzBgSoft">@color/mz_bg_soft</item>
        <item name="mzCard">@color/mz_card</item>
        <item name="mzCardSoft">@color/mz_card_soft</item>
        <item name="mzBgSurface">@color/mz_bg_surface</item>
        <item name="mzText">@color/mz_text</item>
        <item name="mzMuted">@color/mz_muted</item>
        <item name="mzBorderSoft">@color/mz_border_soft</item>
        <item name="mzBorderStrong">@color/mz_border_strong</item>
        <item name="mzPrimary">@color/mz_primary</item>
        <item name="mzPrimaryAlt">@color/mz_primary_alt</item>
        <item name="mzAccent">@color/mz_accent</item>
        <item name="mzLime">@color/mz_lime</item>
        <item name="mzSuccess">@color/mz_success</item>
        <item name="mzDanger">@color/mz_danger</item>
        <item name="mzDangerSoft">@color/mz_danger_soft</item>
        <item name="mzToolbarGradStart">@color/mz_toolbar_grad_start</item>
        <item name="mzToolbarGradEnd">@color/mz_toolbar_grad_end</item>
        
        <item name="planWeekHeaderSelectedBg">@color/plan_week_header_selected_bg</item>
        <item name="planWeekDaySelectedBg">@color/plan_week_day_selected_bg</item>

        <!-- Plan Defaults -->
        <item name="mzPlanHourLine">@color/plan_hour_line</item>
        <item name="mzPlanNowLine">@color/plan_now_line</item>
        <item name="mzPlanColumnText">@color/plan_time_column_text</item>
        <item name="mzPlanHeaderText">@color/plan_week_header_text</item>
        <item name="mzPlanGridBg">@color/plan_week_day_bg</item>
        <item name="mzPlanGridBgSelected">@color/plan_week_day_selected_bg</item>
        <item name="mzPlanEventTextColor">@color/plan_event_text</item>
    </style>

    <!-- Deep Blue Theme (Day/Light) -->
    <style name="Theme.MZUTv2.DeepBlue" parent="Base.Theme.MZUTv2">
        <item name="colorPrimary">#1E3A8A</item> <!-- Blue 900 -->
        <item name="colorPrimaryVariant">#172554</item> <!-- Blue 950 -->
        <item name="colorOnPrimary">#FFFFFF</item>

        <!-- Overrides for Deep Blue -->
        <item name="mzBg">#F0F8FF</item> <!-- AliceBlue -->
        <item name="mzBgSoft">#E0F2FE</item> <!-- Sky 100 -->
        <item name="mzCard">#FFFFFF</item>
        <item name="mzCardSoft">#F1F5F9</item>
        <item name="mzBgSurface">#FFFFFF</item>
        <item name="mzText">#1E293B</item> <!-- Slate 800 -->
        <item name="mzMuted">#64748B</item> <!-- Slate 500 -->
        <item name="mzBorderSoft">#E2E8F0</item>
        <item name="mzBorderStrong">#94A3B8</item>
        <item name="mzPrimary">#1E3A8A</item>
        <item name="mzLime">@color/mz_lime</item>
        <item name="mzToolbarGradStart">#FFFFFF</item>
        <item name="mzToolbarGradEnd">#F0F8FF</item>
        
        <item name="android:statusBarColor">#F0F8FF</item> 
        <item name="android:windowLightStatusBar">true</item>
        <item name="android:windowLightNavigationBar">true</item>

        <!-- Plan Deep Blue Overrides -->
        <item name="mzPlanHourLine">#20000000</item> 
        <item name="mzPlanNowLine">#DC2626</item> <!-- Red 600 -->
        <item name="mzPlanColumnText">#334155</item> 
        <item name="mzPlanHeaderText">#1E293B</item>
        <item name="mzPlanGridBg">@android:color/transparent</item> 
        <item name="mzPlanGridBgSelected">#201E3A8A</item> 
        <item name="mzPlanEventTextColor">#1E293B</item>
        <item name="planWeekHeaderSelectedBg">#DBEAFE</item>
        <item name="planWeekDaySelectedBg">#EFF6FF</item>
    </style>



    <!-- Lime Theme (Day/Light) -->
    <style name="Theme.MZUTv2.Lime" parent="Base.Theme.MZUTv2">
        <item name="colorPrimary">#65A30D</item>
        <item name="colorPrimaryVariant">#4D7C0F</item>
        <item name="colorOnPrimary">#FFFFFF</item>

        <item name="mzBg">#F4FFF6</item>
        <item name="mzBgSoft">#ECFDF3</item>
        <item name="mzCard">#FFFFFF</item>
        <item name="mzCardSoft">#F0FDF4</item>
        <item name="mzBgSurface">#FFFFFF</item>
        <item name="mzText">#1E293B</item>
        <item name="mzMuted">#64748B</item>
        <item name="mzBorderSoft">#DCFCE7</item>
        <item name="mzBorderStrong">#A7F3D0</item>
        <item name="mzPrimary">#65A30D</item>
        <item name="mzPrimaryAlt">#4D7C0F</item>
        <item name="mzAccent">#22C55E</item>
        <item name="mzLime">@color/mz_lime</item>
        <item name="mzToolbarGradStart">#FFFFFF</item>
        <item name="mzToolbarGradEnd">#F4FFF6</item>

        <item name="android:statusBarColor">#F4FFF6</item>
        <item name="android:windowLightStatusBar">true</item>
        <item name="android:windowLightNavigationBar">true</item>

        <!-- Plan Lime Overrides -->
        <item name="mzPlanHourLine">#1A14532D</item>
        <item name="mzPlanNowLine">#DC2626</item>
        <item name="mzPlanColumnText">#334155</item>
        <item name="mzPlanHeaderText">#1E293B</item>
        <item name="mzPlanGridBg">@android:color/transparent</item>
        <item name="mzPlanGridBgSelected">#2065A30D</item>
        <item name="mzPlanEventTextColor">#1E293B</item>
        <item name="planWeekHeaderSelectedBg">#DCFCE7</item>
        <item name="planWeekDaySelectedBg">#ECFDF3</item>
    </style>
    <!-- High Contrast Theme (Day) - Accessibility focused -->
    <style name="Theme.MZUTv2.HighContrast" parent="Base.Theme.MZUTv2">
        <item name="colorPrimary">#000000</item>
        <item name="colorPrimaryVariant">#000000</item>
        <item name="colorOnPrimary">#FFFFFF</item>

        <!-- High Contrast - Pure white bg, black text -->
        <item name="mzBg">#FFFFFF</item>
        <item name="mzBgSoft">#F5F5F5</item>
        <item name="mzCard">#FFFFFF</item>
        <item name="mzCardSoft">#EEEEEE</item>
        <item name="mzBgSurface">#FFFFFF</item>
        <item name="mzText">#000000</item>
        <item name="mzMuted">#333333</item>
        <item name="mzBorderSoft">#000000</item>
        <item name="mzBorderStrong">#000000</item>
        <item name="mzPrimary">#0000EE</item>
        <item name="mzPrimaryAlt">#0000CC</item>
        <item name="mzAccent">#0000EE</item>
        <item name="mzLime">@color/mz_lime</item>
        <item name="mzSuccess">#006600</item>
        <item name="mzDanger">#CC0000</item>
        <item name="mzDangerSoft">#FFCCCC</item>
        <item name="mzToolbarGradStart">#FFFFFF</item>
        <item name="mzToolbarGradEnd">#FFFFFF</item>

        <item name="android:statusBarColor">#FFFFFF</item>
        <item name="android:windowLightStatusBar">true</item>
        <item name="android:windowLightNavigationBar">true</item>

        <!-- Plan High Contrast -->
        <item name="mzPlanHourLine">#000000</item>
        <item name="mzPlanNowLine">#CC0000</item>
        <item name="mzPlanColumnText">#000000</item>
        <item name="mzPlanHeaderText">#000000</item>
        <item name="mzPlanGridBg">#FFFFFF</item>
        <item name="mzPlanGridBgSelected">#DDDDDD</item>
        <item name="mzPlanEventTextColor">#000000</item>
        <item name="planWeekHeaderSelectedBg">#CCCCCC</item>
        <item name="planWeekDaySelectedBg">#EEEEEE</item>
    </style>

    <!-- Dialog Theme for Custom Event Wizard -->
    <style name="Theme.MZUTv2.Dialog" parent="Theme.MaterialComponents.DayNight.Dialog">
        <item name="android:windowBackground">@drawable/bg_dialog_rounded</item>
        <item name="android:windowMinWidthMajor">90%</item>
        <item name="android:windowMinWidthMinor">90%</item>
        <item name="colorPrimary">@color/mz_primary</item>
        <item name="colorOnPrimary">@android:color/white</item>
        <item name="mzBgSurface">@color/mz_bg_surface</item>
        <item name="mzText">@color/mz_text</item>
        <item name="mzMuted">@color/mz_muted</item>
        <item name="mzPrimary">@color/mz_primary</item>
        <item name="mzLime">@color/mz_lime</item>
    </style>


</resources>
