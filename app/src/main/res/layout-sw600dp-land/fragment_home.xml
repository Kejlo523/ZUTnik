<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/drawerContentRoot"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <include
        android:id="@+id/homeSkeleton"
        layout="@layout/skeleton_home"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:visibility="gone" />

    <LinearLayout
        android:id="@+id/homeContentRoot"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical">

        <androidx.appcompat.widget.Toolbar
            android:id="@+id/toolbar"
            style="@style/Widget.ZUTnik.Toolbar"
            android:layout_width="match_parent"
            android:layout_height="?attr/actionBarSize"
            android:background="@drawable/bg_toolbar"
            android:elevation="0dp"
            android:paddingStart="20dp"
            android:paddingEnd="20dp"
            android:titleTextColor="?attr/mzNavHeaderText" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:baselineAligned="false"
            android:orientation="horizontal"
            android:paddingStart="18dp"
            android:paddingTop="12dp"
            android:paddingEnd="18dp"
            android:paddingBottom="16dp">

            <ScrollView
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_marginEnd="14dp"
                android:layout_weight="0.36"
                android:clipToPadding="false"
                android:fillViewport="true"
                android:overScrollMode="ifContentScrolls"
                android:scrollbars="none">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="@android:color/transparent"
                    android:orientation="vertical"
                    android:padding="18dp">

                    <LinearLayout
                        android:id="@+id/homeHero"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:background="@android:color/transparent"
                        android:gravity="center_horizontal"
                        android:orientation="vertical"
                        android:paddingStart="18dp"
                        android:paddingTop="16dp"
                        android:paddingEnd="18dp"
                        android:paddingBottom="16dp">

                        <ImageView
                            android:layout_width="56dp"
                            android:layout_height="56dp"
                            android:contentDescription="@string/app_name"
                            android:src="@drawable/ic_zut_logo_inapp" />

                        <TextView
                            android:id="@+id/textWelcome"
                            style="@style/TextAppearance.ZUTnik.Display"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="12dp"
                            android:gravity="center"
                            android:text="@string/home_welcome_fallback"
                            android:textColor="?attr/mzText" />

                        <TextView
                            android:id="@+id/textWelcomeSub"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="6dp"
                            android:gravity="center"
                            android:lineSpacingExtra="2dp"
                            android:text="@string/home_welcome_subtitle"
                            android:textColor="?attr/mzMuted"
                            android:textSize="14sp" />
                    </LinearLayout>

                    <LinearLayout
                        android:id="@+id/homeSection"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="16dp"
                        android:background="@android:color/transparent"
                        android:orientation="vertical"
                        android:padding="14dp">

                        <TextView
                            android:id="@+id/textFooterMeta"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:gravity="center"
                            android:lineSpacingExtra="3dp"
                            android:text="@string/home_footer_meta"
                            android:textColor="?attr/mzMuted"
                            android:textSize="12sp" />
                    </LinearLayout>
                </LinearLayout>
            </ScrollView>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="0.64"
                android:background="@android:color/transparent"
                android:orientation="vertical"
                android:paddingStart="18dp"
                android:paddingTop="16dp"
                android:paddingEnd="18dp"
                android:paddingBottom="12dp">

                <TextView
                    style="@style/TextAppearance.ZUTnik.Section"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="12dp"
                    android:letterSpacing="0"
                    android:text="@string/home_shortcuts_title"
                    android:textColor="?attr/mzText" />

                <ScrollView
                    android:layout_width="match_parent"
                    android:layout_height="0dp"
                    android:layout_weight="1"
                    android:clipToPadding="false"
                    android:fillViewport="true"
                    android:overScrollMode="ifContentScrolls"
                    android:scrollbars="vertical">

                    <pl.kejlo.zutnik.TileGridLayout
                        android:id="@+id/tileGrid"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content" />
                </ScrollView>
            </LinearLayout>
        </LinearLayout>
    </LinearLayout>

    <include layout="@layout/view_home_edit_dock" />

    <androidx.cardview.widget.CardView
        android:id="@+id/indicatorOverlay"
        android:layout_width="52dp"
        android:layout_height="52dp"
        android:layout_gravity="bottom|start"
        android:layout_margin="24dp"
        android:visibility="gone"
        app:cardBackgroundColor="?attr/mzPrimary"
        app:cardCornerRadius="26dp"
        app:cardElevation="6dp">

        <ImageView
            android:id="@+id/indicatorIcon"
            android:layout_width="26dp"
            android:layout_height="26dp"
            android:layout_gravity="center"
            android:src="@drawable/ic_check"
            app:tint="?attr/colorOnPrimary" />
    </androidx.cardview.widget.CardView>

</FrameLayout>
