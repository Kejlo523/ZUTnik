<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/wear_bg">

    <ScrollView
        android:id="@+id/wearRootScroll"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true"
        android:overScrollMode="never">

        <LinearLayout
            android:id="@+id/wearContentRoot"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="12dp"
            android:paddingEnd="12dp"
            android:paddingTop="12dp"
            android:paddingBottom="24dp">

        <TextView
            android:id="@+id/wearWeekLabel"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="2dp"
            android:textColor="#9AA0A6"
            android:textSize="11sp"
            android:text="@string/wear_main_week_label" />

        <LinearLayout
            android:id="@+id/weekContainer"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:orientation="vertical" />

        <LinearLayout
            android:id="@+id/wearStatusCard"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:orientation="vertical"
            android:background="@drawable/wear_card"
            android:padding="10dp"
                android:visibility="gone">

            <TextView
                android:id="@+id/wearStatus"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="#E6EDF7"
                android:textSize="12sp"
                android:gravity="center"
                android:text="@string/wear_main_status_waiting" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <ProgressBar
                    android:id="@+id/wearProgress"
                    style="?android:attr/progressBarStyleHorizontal"
                    android:layout_width="0dp"
                    android:layout_height="6dp"
                    android:layout_weight="1"
                    android:indeterminate="false"
                    android:max="100"
                    android:progress="0"
                    android:progressTint="#7FA7FF"
                    android:progressBackgroundTint="#24304A"
                    android:visibility="gone" />

                <TextView
                    android:id="@+id/wearProgressText"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="8dp"
                    android:textColor="#B0B7C3"
                    android:textSize="10sp"
                    android:text="@string/common_percent_zero"
                    android:visibility="gone" />
            </LinearLayout>
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <Button
                android:id="@+id/btnWearSync"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="@string/wear_main_sync"
                android:textColor="@android:color/white"
                android:background="@drawable/wear_button"
                android:paddingStart="16dp"
                android:paddingEnd="16dp" />

            <ImageButton
                android:id="@+id/btnWearCancel"
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:layout_marginStart="8dp"
                android:background="@android:color/transparent"
                android:src="@android:drawable/ic_menu_close_clear_cancel"
                android:tint="#B0B7C3"
                android:contentDescription="@string/wear_main_status_declined"
                android:visibility="gone" />
        </LinearLayout>

        <TextView
            android:id="@+id/wearTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:textColor="@android:color/white"
            android:textSize="16sp"
            android:textStyle="bold"
            android:gravity="center"
            android:text="@string/wear_main_title" />

        <TextView
            android:id="@+id/wearDesc"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:textColor="#B0B7C3"
            android:textSize="12sp"
            android:gravity="center"
            android:text="@string/wear_main_desc" />

        </LinearLayout>
    </ScrollView>
</FrameLayout>
