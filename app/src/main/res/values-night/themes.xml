<resources xmlns:tools="http://schemas.android.com/tools">

    <!-- Base Application Theme (Night) -->
    <style name="Base.Theme.ZUTnik" parent="Theme.MaterialComponents.DayNight.NoActionBar">
        <item name="colorPrimaryDark">?attr/mzBg</item>
        <item name="android:windowLightStatusBar">false</item>
        <item name="android:windowBackground">?attr/mzBg</item>

        <item name="android:windowLightNavigationBar" tools:targetApi="27">false</item>

        <!-- No Title -->
        <item name="windowActionBar">false</item>
        <item name="android:windowActionBar">false</item>
        <item name="windowNoTitle">true</item>

        <!-- Splash -->
        <item name="android:windowSplashScreenBackground" tools:targetApi="31">?attr/mzBg</item>
        <item name="android:windowSplashScreenAnimatedIcon" tools:targetApi="31">@mipmap/ic_zut_logo_round</item>
        <item name="android:windowSplashScreenAnimationDuration" tools:targetApi="31">200</item>
        <item name="android:windowSplashScreenIconBackgroundColor" tools:targetApi="31">@android:color/transparent</item>

        <!-- Dialogs & Popups -->
        <item name="materialAlertDialogTheme">@style/ThemeOverlay.ZUTnik.AlertDialog</item>
        <item name="popupMenuStyle">@style/Widget.ZUTnik.PopupMenu</item>
        <item name="android:popupMenuStyle">@style/Widget.ZUTnik.PopupMenu</item>

        <item name="mzNavHeader">@color/mz_nav_header</item>
        <item name="mzNavHeaderText">@color/mz_nav_header_text</item>
        <item name="toolbarStyle">@style/Widget.ZUTnik.Toolbar</item>
    </style>

    <!-- Default Theme (Night/Reference) uses colors.xml (Night resource resolution) -->
    <!-- Note: colors.xml automatically handles night values if in values-night/colors.xml. -->
    <!-- However, we must map the attributes here just like in values/themes.xml -->
    <style name="Theme.ZUTnik" parent="Base.Theme.ZUTnik">
        <item name="colorPrimary">@color/mz_primary</item>
        <item name="colorPrimaryVariant">@color/mz_primary_alt</item>
        <item name="colorOnPrimary">@color/mz_text</item>

        <item name="mzBg">@color/mz_bg</item>
        <item name="mzBgSoft">@color/mz_bg_soft</item>
        <item name="mzCard">@color/mz_card</item>
        <item name="mzCardSoft">@color/mz_card_soft</item>
        <item name="mzBgSurface">@color/mz_bg_surface</item>
        <item name="mzInputBg">@color/mz_bg</item>
        <item name="mzText">@color/mz_text</item>
        <item name="mzMuted">@color/mz_muted</item>
        <item name="mzBorderSoft">@color/mz_border_soft</item>
        <item name="mzBorderStrong">@color/mz_border_strong</item>
        <item name="mzPrimary">@color/mz_primary</item>
        <item name="mzPrimaryAlt">@color/mz_primary_alt</item>
        <item name="mzAccent">@color/mz_accent</item>
        <item name="mzLime">@color/mz_lime</item>
        <item name="mzSuccess">@color/mz_success</item>
        <item name="mzDanger">@color/mz_danger</item>
        <item name="mzDangerSoft">@color/mz_danger_soft</item>
        <item name="mzToolbarGradStart">@color/mz_toolbar_grad_start</item>
        <item name="mzToolbarGradEnd">@color/mz_toolbar_grad_end</item>
        <item name="mzNavHeader">@color/mz_nav_header</item>
        <item name="mzNavHeaderText">@color/mz_nav_header_text</item>
        
        <item name="planWeekHeaderSelectedBg">@color/plan_week_header_selected_bg</item>
        <item name="planWeekDaySelectedBg">@color/plan_week_day_selected_bg</item>

        <!-- Plan Night Defaults -->
        <item name="mzPlanHourLine">#20FFFFFF</item>
        <item name="mzPlanNowLine">@color/plan_now_line</item>
        <item name="mzPlanColumnText">@color/mz_muted</item>
        <item name="mzPlanHeaderText">@color/mz_text</item>
        <item name="mzPlanGridBg">@android:color/transparent</item>
        <item name="mzPlanGridBgSelected">#12FFFFFF</item>
        <item name="mzPlanEventTextColor">#E2E8F0</item>
    </style>

    <!-- Deep Blue Theme (Night) -->
    <style name="Theme.ZUTnik.DeepBlue" parent="Base.Theme.ZUTnik">
        <item name="colorPrimary">#60A5FA</item> <!-- Blue 400 -->
        <item name="colorPrimaryVariant">#3B82F6</item> <!-- Blue 500 -->
        <item name="colorOnPrimary">#FFFFFF</item>

        <!-- Overrides for Deep Blue Night -->
        <item name="mzBg">#0F172A</item> <!-- Slate 900 -->
        <item name="mzBgSoft">#1E293B</item> <!-- Slate 800 -->
        <item name="mzCard">#1E293B</item>
        <item name="mzCardSoft">#334155</item> <!-- Slate 700 -->
        <item name="mzBgSurface">#0F172A</item>
        <item name="mzInputBg">#0F172A</item>
        <item name="mzText">#F1F5F9</item> <!-- Slate 100 -->
        <item name="mzMuted">#94A3B8</item> <!-- Slate 400 -->
        <item name="mzBorderSoft">#334155</item>
        <item name="mzBorderStrong">#475569</item>
        <item name="mzPrimary">#60A5FA</item>
        <item name="mzPrimaryAlt">#3B82F6</item>
        <item name="mzAccent">#38BDF8</item>
        <item name="mzLime">@color/mz_lime</item>
        <item name="mzSuccess">#22C55E</item>
        <item name="mzDanger">#F87171</item>
        <item name="mzDangerSoft">#3B1C1C</item>
        <item name="mzNavHeader">#0F172A</item>
        <item name="mzNavHeaderText">#FFFFFF</item>
        
        <item name="android:windowLightStatusBar">false</item>
        <item name="android:windowLightNavigationBar" tools:targetApi="27">false</item>

        <!-- Plan Deep Blue Overrides -->
        <item name="mzPlanHourLine">#20FFFFFF</item> 
        <item name="mzPlanNowLine">#F87171</item> <!-- Red 400 -->
        <item name="mzPlanColumnText">#94A3B8</item> 
        <item name="mzPlanHeaderText">#F1F5F9</item>
        <item name="mzPlanGridBg">@android:color/transparent</item> 
        <item name="mzPlanGridBgSelected">#2060A5FA</item> 
        <item name="mzPlanEventTextColor">#F1F5F9</item>
        <item name="planWeekHeaderSelectedBg">#1E293B</item>
        <item name="planWeekDaySelectedBg">#334155</item>
    </style>



    <!-- Lime Theme (Night) -->
    <style name="Theme.ZUTnik.Lime" parent="Base.Theme.ZUTnik">
        <item name="colorPrimary">#65A30D</item>
        <item name="colorPrimaryVariant">#4D7C0F</item>
        <item name="colorOnPrimary">#FFFFFF</item>

        <item name="mzBg">#0F1A12</item>
        <item name="mzBgSoft">#16261A</item>
        <item name="mzCard">#16261A</item>
        <item name="mzCardSoft">#203224</item>
        <item name="mzBgSurface">#0F1A12</item>
        <item name="mzInputBg">#0F1A12</item>
        <item name="mzText">#F1F5F9</item>
        <item name="mzMuted">#94A3B8</item>
        <item name="mzBorderSoft">#203224</item>
        <item name="mzBorderStrong">#2F3F30</item>
        <item name="mzPrimary">#65A30D</item>
        <item name="mzPrimaryAlt">#4D7C0F</item>
        <item name="mzAccent">#22C55E</item>
        <item name="mzLime">@color/mz_lime</item>
        <item name="mzSuccess">#22C55E</item>
        <item name="mzDanger">#F87171</item>
        <item name="mzDangerSoft">#3B1C1C</item>
        <item name="mzNavHeader">#1B3A1E</item>
        <item name="mzNavHeaderText">#FFFFFF</item>

        <item name="android:windowLightStatusBar">false</item>
        <item name="android:windowLightNavigationBar" tools:targetApi="27">false</item>

        <!-- Plan Lime Overrides -->
        <item name="mzPlanHourLine">#20FFFFFF</item>
        <item name="mzPlanNowLine">#F87171</item>
        <item name="mzPlanColumnText">#94A3B8</item>
        <item name="mzPlanHeaderText">#F1F5F9</item>
        <item name="mzPlanGridBg">@android:color/transparent</item>
        <item name="mzPlanGridBgSelected">#2065A30D</item>
        <item name="mzPlanEventTextColor">#F1F5F9</item>
        <item name="planWeekHeaderSelectedBg">#1B2E1F</item>
        <item name="planWeekDaySelectedBg">#243326</item>
    </style>
    <!-- High Contrast Theme (Night) - Accessibility focused -->
    <style name="Theme.ZUTnik.HighContrast" parent="Base.Theme.ZUTnik">
        <item name="colorPrimary">#FFFFFF</item>
        <item name="colorPrimaryVariant">#FFFFFF</item>
        <item name="colorOnPrimary">#000000</item>

        <!-- High Contrast Night - Pure black bg, bright white text -->
        <item name="mzBg">#000000</item>
        <item name="mzBgSoft">#111111</item>
        <item name="mzCard">#111111</item>
        <item name="mzCardSoft">#222222</item>
        <item name="mzBgSurface">#000000</item>
        <item name="mzInputBg">#000000</item>
        <item name="mzText">#FFFFFF</item>
        <item name="mzMuted">#CCCCCC</item>
        <item name="mzBorderSoft">#FFFFFF</item>
        <item name="mzBorderStrong">#FFFFFF</item>
        <item name="mzPrimary">#00FFFF</item>
        <item name="mzPrimaryAlt">#00CCCC</item>
        <item name="mzAccent">#00FFFF</item>
        <item name="mzLime">@color/mz_lime</item>
        <item name="mzSuccess">#00FF00</item>
        <item name="mzDanger">#FF0000</item>
        <item name="mzDangerSoft">#330000</item>
        <item name="mzToolbarGradStart">#000000</item>
        <item name="mzToolbarGradEnd">#000000</item>
        <item name="mzNavHeader">#111111</item>
        <item name="mzNavHeaderText">#FFFFFF</item>

        <item name="android:windowLightStatusBar">false</item>
        <item name="android:windowLightNavigationBar" tools:targetApi="27">false</item>

        <!-- Plan High Contrast Night -->
        <item name="mzPlanHourLine">#FFFFFF</item>
        <item name="mzPlanNowLine">#FF0000</item>
        <item name="mzPlanColumnText">#FFFFFF</item>
        <item name="mzPlanHeaderText">#FFFFFF</item>
        <item name="mzPlanGridBg">#000000</item>
        <item name="mzPlanGridBgSelected">#333333</item>
        <item name="mzPlanEventTextColor">#FFFFFF</item>
        <item name="planWeekHeaderSelectedBg">#333333</item>
        <item name="planWeekDaySelectedBg">#222222</item>
    </style>


</resources>
