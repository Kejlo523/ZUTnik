<?xml version="1.0" encoding="utf-8"?>
<androidx.drawerlayout.widget.DrawerLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/drawerLayout"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/mz_bg"
    android:fitsSystemWindows="true"
    app:statusBarBackground="@color/mz_bg">

    <!-- GŁÓWNA ZAWARTOŚĆ EKRANU -->
    <LinearLayout
        android:orientation="vertical"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fitsSystemWindows="true">

        <!-- TOOLBAR -->
        <androidx.appcompat.widget.Toolbar
            android:id="@+id/toolbar"
            android:layout_width="match_parent"
            android:layout_height="?attr/actionBarSize"
            android:background="@color/mz_bg"
            android:popupTheme="@style/ThemeOverlay.AppCompat.Dark" />

        <!-- TREŚĆ -->
        <LinearLayout
            android:id="@+id/planContentRoot"
            android:orientation="vertical"
            android:padding="12dp"
            android:layout_width="match_parent"
            android:layout_height="match_parent">

            <!-- PRZEŁĄCZNIK WIDOKÓW -->
            <LinearLayout
                android:id="@+id/layoutViewModesRow"
                android:orientation="horizontal"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:paddingTop="4dp"
                android:paddingBottom="4dp">

                <Button
                    android:id="@+id/btnViewDay"
                    android:text="@string/plan_view_day"
                    android:textSize="13sp"
                    android:background="@drawable/bg_mode_button"
                    android:textColor="@color/mz_text"
                    android:layout_width="0dp"
                    android:layout_height="36dp"
                    android:layout_weight="1"
                    android:layout_marginRight="4dp"
                    android:textAllCaps="false" />

                <Button
                    android:id="@+id/btnViewWeek"
                    android:text="@string/plan_view_week"
                    android:textSize="13sp"
                    android:background="@drawable/bg_mode_button"
                    android:textColor="@color/mz_text"
                    android:layout_width="0dp"
                    android:layout_height="36dp"
                    android:layout_weight="1"
                    android:layout_marginLeft="2dp"
                    android:layout_marginRight="2dp"
                    android:textAllCaps="false" />

                <Button
                    android:id="@+id/btnViewMonth"
                    android:text="@string/plan_view_month"
                    android:textSize="13sp"
                    android:background="@drawable/bg_mode_button"
                    android:textColor="@color/mz_text"
                    android:layout_width="0dp"
                    android:layout_height="36dp"
                    android:layout_weight="1"
                    android:layout_marginLeft="4dp"
                    android:textAllCaps="false" />
            </LinearLayout>

            <!-- NAGŁÓWEK ZAKRESU + AKCJE W PRAWYM GÓRNYM ROGU -->
            <LinearLayout
                android:id="@+id/layoutHeaderActionsRow"
                android:orientation="horizontal"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:paddingBottom="4dp">

                <TextView
                    android:id="@+id/tvHeaderLabel"
                    android:text="-"
                    android:textSize="14sp"
                    android:textColor="@color/mz_text"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1" />

                <LinearLayout
                    android:orientation="horizontal"
                    android:gravity="center"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content">

                    <Button
                        android:id="@+id/btnToday"
                        android:text="@string/plan_button_today"
                        android:textSize="12sp"
                        android:background="@drawable/bg_mode_button"
                        android:textColor="@color/mz_text"
                        android:minHeight="0dp"
                        android:minWidth="0dp"
                        android:layout_width="wrap_content"
                        android:layout_height="32dp"
                        android:paddingLeft="10dp"
                        android:paddingRight="10dp"
                        android:textAllCaps="false" />

                    <Button
                        android:id="@+id/btnRefresh"
                        android:text="@string/plan_button_refresh"
                        android:textSize="12sp"
                        android:background="@drawable/bg_mode_button"
                        android:textColor="@color/mz_text"
                        android:minHeight="0dp"
                        android:minWidth="0dp"
                        android:layout_width="wrap_content"
                        android:layout_height="32dp"
                        android:layout_marginLeft="6dp"
                        android:paddingLeft="10dp"
                        android:paddingRight="10dp"
                        android:textAllCaps="false" />

                    <Button
                        android:id="@+id/btnFilters"
                        android:text="@string/plan_button_filters"
                        android:textSize="11sp"
                        android:background="@drawable/bg_mode_button"
                        android:textColor="@color/mz_text"
                        android:layout_width="wrap_content"
                        android:layout_height="32dp"
                        android:layout_marginLeft="6dp"
                        android:paddingLeft="10dp"
                        android:paddingRight="10dp"
                        android:textAllCaps="false" />
                </LinearLayout>
            </LinearLayout>

            <!-- NAWIGACJA: STRZAŁKA LEWO / PRAWO NAD KALENDARZEM -->
            <LinearLayout
                android:id="@+id/layoutArrowsTop"
                android:orientation="horizontal"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:paddingBottom="6dp"
                android:gravity="center_vertical">

                <!-- LEWY PRZYCISK – DOLEGA DO LEWEJ KRAWĘDZI -->
                <Button
                    android:id="@+id/btnPrev"
                    android:text="@string/plan_nav_prev"
                    android:textSize="18sp"
                    android:background="@drawable/bg_mode_button"
                    android:textColor="@color/mz_text"
                    android:minWidth="0dp"
                    android:minHeight="0dp"
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:textAllCaps="false"
                    android:layout_marginStart="0dp" />

                <!-- PUSTA PRZESTRZEŃ -->
                <View
                    android:layout_width="0dp"
                    android:layout_height="0dp"
                    android:layout_weight="1" />

                <!-- PRAWY PRZYCISK – DOLEGA DO PRAWEJ KRAWĘDZI -->
                <Button
                    android:id="@+id/btnNext"
                    android:text="@string/plan_nav_next"
                    android:textSize="18sp"
                    android:background="@drawable/bg_mode_button"
                    android:textColor="@color/mz_text"
                    android:minWidth="0dp"
                    android:minHeight="0dp"
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:textAllCaps="false"
                    android:layout_marginEnd="0dp" />

            </LinearLayout>

            <!-- SCROLL NA PLAN -->
            <ScrollView
                android:id="@+id/scrollPlan"
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="1"
                android:fillViewport="true"
                android:scrollbars="vertical">

                <LinearLayout
                    android:id="@+id/planScrollContent"
                    android:orientation="vertical"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content">

                    <!-- PLAN WEEK/DAY -->
                    <LinearLayout
                        android:id="@+id/layoutWeekRoot"
                        android:orientation="horizontal"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:background="@color/mz_bg">

                        <LinearLayout
                            android:id="@+id/layoutTimeColumn"
                            android:orientation="vertical"
                            android:layout_width="36dp"
                            android:layout_height="wrap_content"
                            android:paddingTop="32dp"
                            android:paddingRight="2dp" />

                        <LinearLayout
                            android:id="@+id/layoutWeekDays"
                            android:orientation="horizontal"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1" />
                    </LinearLayout>

                    <!-- PLAN MONTH -->
                    <LinearLayout
                        android:id="@+id/layoutMonthRoot"
                        android:orientation="vertical"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:visibility="gone">

                        <LinearLayout
                            android:id="@+id/layoutMonthWeekdays"
                            android:orientation="horizontal"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:paddingTop="4dp"
                            android:paddingBottom="4dp" />

                        <GridLayout
                            android:id="@+id/gridMonth"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:columnCount="7"
                            android:useDefaultMargins="false" />
                    </LinearLayout>

                </LinearLayout>
            </ScrollView>

            <!-- BRAK ZAJĘĆ -->
            <TextView
                android:id="@+id/tvEmpty"
                android:text="@string/plan_no_classes_in_range"
                android:textColor="@color/mz_muted"
                android:textSize="13sp"
                android:gravity="center"
                android:visibility="gone"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:paddingTop="6dp"
                android:paddingBottom="6dp" />

            <!-- PROGRESS -->
            <ProgressBar
                android:id="@+id/planProgress"
                style="?android:attr/progressBarStyleLarge"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:visibility="gone"
                android:indeterminate="true" />

        </LinearLayout>

    </LinearLayout>

    <!-- NAVIGATION DRAWER -->
    <com.google.android.material.navigation.NavigationView
        android:id="@+id/navigationView"
        android:layout_width="wrap_content"
        android:layout_height="match_parent"
        android:layout_gravity="start"
        android:background="@color/mz_bg"
        android:fitsSystemWindows="true">

        <include
            layout="@layout/nav_header"
            android:layout_width="match_parent"
            android:layout_height="match_parent" />

    </com.google.android.material.navigation.NavigationView>

</androidx.drawerlayout.widget.DrawerLayout>
