<?xml version="1.0" encoding="utf-8"?>
<androidx.drawerlayout.widget.DrawerLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/drawerLayout"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_app"
    android:fitsSystemWindows="true"
    app:statusBarBackground="@color/mz_bg">

    <!-- Główna część ekranu -->
    <LinearLayout
        android:orientation="vertical"
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <!-- Toolbar spójny z innymi ekranami -->
        <androidx.appcompat.widget.Toolbar
            android:id="@+id/toolbar"
            android:layout_width="match_parent"
            android:layout_height="?attr/actionBarSize"
            android:background="@drawable/bg_toolbar"
            android:theme="@style/ThemeOverlay.AppCompat.Dark.ActionBar"
            android:titleTextColor="@color/mz_text"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:elevation="0dp" />

        <!-- Treść ekranu -->
        <ScrollView
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:background="@android:color/transparent"
            android:overScrollMode="ifContentScrolls">

            <LinearLayout
                android:id="@+id/infoContent"
                android:orientation="vertical"
                android:padding="16dp"
                android:layout_width="match_parent"
                android:layout_height="wrap_content">

                <!-- HERO / nagłówek -->
                <LinearLayout
                    android:orientation="vertical"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:paddingBottom="16dp">

                    <!-- mały pill -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:paddingStart="12dp"
                        android:paddingEnd="12dp"
                        android:paddingTop="6dp"
                        android:paddingBottom="6dp"
                        android:background="@drawable/bg_card_soft"
                        android:text="🎓 Dane Studenta"
                        android:textColor="@color/mz_primary"
                        android:textSize="11sp" />

                    <TextView
                        android:id="@+id/tvInfoTitle"
                        android:text="Dane"
                        android:textSize="20sp"
                        android:textStyle="bold"
                        android:textColor="@color/mz_text"
                        android:layout_marginTop="10dp"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content" />

                    <TextView
                        android:id="@+id/tvInfoSubtitle"
                        android:text="Dane z systemów ZUT: kierunek, status, semestr oraz przebieg studiów — w jednym miejscu."
                        android:textSize="13sp"
                        android:textColor="@color/mz_muted"
                        android:layout_marginTop="4dp"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content" />
                </LinearLayout>

                <!-- KARTA: profil studenta (avatar + podstawowe dane) -->
                <LinearLayout
                    android:orientation="horizontal"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="@drawable/bg_card_soft"
                    android:padding="12dp">

                    <!-- AVATAR STUDENTA -->
                    <ImageView
                        android:id="@+id/imageInfoAvatar"
                        android:layout_width="64dp"
                        android:layout_height="64dp"
                        android:background="@drawable/bg_avatar_round"
                        android:padding="2dp"
                        android:scaleType="centerCrop"
                        android:clipToOutline="true"
                        android:src="@mipmap/ic_launcher_round" />

                    <LinearLayout
                        android:orientation="vertical"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="12dp"
                        android:layout_gravity="center_vertical"
                        android:layout_weight="1">

                        <TextView
                            android:id="@+id/tvInfoName"
                            android:text="Student"
                            android:textSize="16sp"
                            android:textStyle="bold"
                            android:textColor="@color/mz_text"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content" />

                        <TextView
                            android:id="@+id/tvInfoUserId"
                            android:text="ID użytkownika: -"
                            android:textSize="12sp"
                            android:textColor="@color/mz_muted"
                            android:layout_marginTop="2dp"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content" />
                    </LinearLayout>
                </LinearLayout>

                <!-- 🔁 Przełącznik kierunków -->
                <LinearLayout
                    android:orientation="vertical"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Kierunek / program studiów"
                        android:textSize="12sp"
                        android:textColor="@color/mz_text"
                        android:layout_marginBottom="4dp" />

                    <Spinner
                        android:id="@+id/spinnerStudies"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:background="@android:color/transparent"
                        android:popupBackground="@color/mz_bg"
                        android:padding="4dp" />
                </LinearLayout>

                <!-- Karta: aktualne studia -->
                <LinearLayout
                    android:orientation="vertical"
                    android:padding="12dp"
                    android:background="@drawable/bg_card_soft"
                    android:layout_marginTop="16dp"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content">

                    <TextView
                        android:text="Aktualne studia"
                        android:textSize="15sp"
                        android:textStyle="bold"
                        android:textColor="@color/mz_text"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content" />

                    <LinearLayout
                        android:orientation="vertical"
                        android:layout_marginTop="8dp"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content">

                        <!-- NR ALBUMU -->
                        <LinearLayout
                            android:orientation="horizontal"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:paddingTop="4dp"
                            android:paddingBottom="4dp">

                            <TextView
                                android:text="Nr albumu:"
                                android:textSize="13sp"
                                android:textColor="@color/mz_muted"
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1" />

                            <TextView
                                android:id="@+id/tvInfoAlbum"
                                android:text="-"
                                android:textSize="13sp"
                                android:textColor="@color/mz_text"
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1" />
                        </LinearLayout>

                        <!-- WYDZIAŁ -->
                        <LinearLayout
                            android:orientation="horizontal"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:paddingTop="4dp"
                            android:paddingBottom="4dp">

                            <TextView
                                android:text="Wydział:"
                                android:textSize="13sp"
                                android:textColor="@color/mz_muted"
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1" />

                            <TextView
                                android:id="@+id/tvInfoWydzial"
                                android:text="-"
                                android:textSize="13sp"
                                android:textColor="@color/mz_text"
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1" />
                        </LinearLayout>

                        <!-- KIERUNEK -->
                        <LinearLayout
                            android:orientation="horizontal"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:paddingTop="4dp"
                            android:paddingBottom="4dp">

                            <TextView
                                android:text="Kierunek:"
                                android:textSize="13sp"
                                android:textColor="@color/mz_muted"
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1" />

                            <TextView
                                android:id="@+id/tvInfoKierunek"
                                android:text="-"
                                android:textSize="13sp"
                                android:textColor="@color/mz_text"
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1" />
                        </LinearLayout>

                        <!-- FORMA -->
                        <LinearLayout
                            android:orientation="horizontal"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:paddingTop="4dp"
                            android:paddingBottom="4dp">

                            <TextView
                                android:text="Forma:"
                                android:textSize="13sp"
                                android:textColor="@color/mz_muted"
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1" />

                            <TextView
                                android:id="@+id/tvInfoForma"
                                android:text="-"
                                android:textSize="13sp"
                                android:textColor="@color/mz_text"
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1" />
                        </LinearLayout>

                        <!-- POZIOM -->
                        <LinearLayout
                            android:orientation="horizontal"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:paddingTop="4dp"
                            android:paddingBottom="4dp">

                            <TextView
                                android:text="Poziom:"
                                android:textSize="13sp"
                                android:textColor="@color/mz_muted"
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1" />

                            <TextView
                                android:id="@+id/tvInfoPoziom"
                                android:text="-"
                                android:textSize="13sp"
                                android:textColor="@color/mz_text"
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1" />
                        </LinearLayout>

                        <!-- SPECJALNOŚĆ -->
                        <LinearLayout
                            android:orientation="horizontal"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:paddingTop="4dp"
                            android:paddingBottom="4dp">

                            <TextView
                                android:text="Specjalność:"
                                android:textSize="13sp"
                                android:textColor="@color/mz_muted"
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1" />

                            <TextView
                                android:id="@+id/tvInfoSpecjalnosc"
                                android:text="-"
                                android:textSize="13sp"
                                android:textColor="@color/mz_text"
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1" />
                        </LinearLayout>

                        <!-- SPECJALIZACJA -->
                        <LinearLayout
                            android:orientation="horizontal"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:paddingTop="4dp"
                            android:paddingBottom="4dp">

                            <TextView
                                android:text="Specjalizacja:"
                                android:textSize="13sp"
                                android:textColor="@color/mz_muted"
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1" />

                            <TextView
                                android:id="@+id/tvInfoSpecjalizacja"
                                android:text="-"
                                android:textSize="13sp"
                                android:textColor="@color/mz_text"
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1" />
                        </LinearLayout>

                        <!-- STATUS -->
                        <LinearLayout
                            android:orientation="horizontal"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:paddingTop="4dp"
                            android:paddingBottom="4dp">

                            <TextView
                                android:text="Status:"
                                android:textSize="13sp"
                                android:textColor="@color/mz_muted"
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1" />

                            <TextView
                                android:id="@+id/tvInfoStatus"
                                android:text="-"
                                android:textSize="13sp"
                                android:textColor="@color/mz_text"
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1" />
                        </LinearLayout>

                        <!-- ROK -->
                        <LinearLayout
                            android:orientation="horizontal"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:paddingTop="4dp"
                            android:paddingBottom="4dp">

                            <TextView
                                android:text="Rok akademicki:"
                                android:textSize="13sp"
                                android:textColor="@color/mz_muted"
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1" />

                            <TextView
                                android:id="@+id/tvInfoRok"
                                android:text="-"
                                android:textSize="13sp"
                                android:textColor="@color/mz_text"
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1" />
                        </LinearLayout>

                        <!-- SEMESTR -->
                        <LinearLayout
                            android:orientation="horizontal"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:paddingTop="4dp"
                            android:paddingBottom="4dp">

                            <TextView
                                android:text="Semestr:"
                                android:textSize="13sp"
                                android:textColor="@color/mz_muted"
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1" />

                            <TextView
                                android:id="@+id/tvInfoSemestr"
                                android:text="-"
                                android:textSize="13sp"
                                android:textColor="@color/mz_text"
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1" />
                        </LinearLayout>
                    </LinearLayout>
                </LinearLayout>

                <!-- Karta: przebieg studiów -->
                <LinearLayout
                    android:orientation="vertical"
                    android:padding="12dp"
                    android:background="@drawable/bg_card_soft"
                    android:layout_marginTop="16dp"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content">

                    <TextView
                        android:text="Przebieg studiów"
                        android:textSize="15sp"
                        android:textStyle="bold"
                        android:textColor="@color/mz_text"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content" />

                    <LinearLayout
                        android:id="@+id/infoHistoryContainer"
                        android:orientation="vertical"
                        android:layout_marginTop="8dp"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content" />
                </LinearLayout>

                <!-- Loading -->
                <TextView
                    android:id="@+id/infoProgress"
                    android:text="Ładowanie danych..."
                    android:textSize="12sp"
                    android:textColor="@color/mz_muted"
                    android:layout_marginTop="12dp"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:visibility="gone" />

            </LinearLayout>
        </ScrollView>
    </LinearLayout>

    <!-- Navigation drawer z nav_header -->
    <com.google.android.material.navigation.NavigationView
        android:id="@+id/navigationView"
        android:layout_width="wrap_content"
        android:layout_height="match_parent"
        android:layout_gravity="start"
        android:background="@color/mz_bg"
        android:fitsSystemWindows="true">

        <include
            layout="@layout/nav_header"
            android:layout_width="match_parent"
            android:layout_height="match_parent" />

    </com.google.android.material.navigation.NavigationView>

</androidx.drawerlayout.widget.DrawerLayout>
