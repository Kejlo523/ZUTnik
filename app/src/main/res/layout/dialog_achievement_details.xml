<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:paddingStart="24dp"
    android:paddingTop="24dp"
    android:paddingEnd="24dp"
    android:paddingBottom="8dp">

    <ImageView
        android:id="@+id/achievementDetailsIcon"
        android:layout_width="88dp"
        android:layout_height="88dp"
        android:layout_gravity="center_horizontal"
        android:contentDescription="@null"
        android:scaleType="fitCenter" />

    <TextView
        android:id="@+id/achievementDetailsState"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center_horizontal"
        android:layout_marginTop="16dp"
        android:fontFamily="sans-serif-medium"
        android:textAllCaps="true"
        android:textColor="?attr/mzPrimary"
        android:textSize="10sp" />

    <TextView
        android:id="@+id/achievementDetailsTitle"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="5dp"
        android:fontFamily="sans-serif-bold"
        android:gravity="center"
        android:textColor="?attr/mzText"
        android:textSize="22sp" />

    <TextView
        android:id="@+id/achievementDetailsDescription"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="10dp"
        android:gravity="center"
        android:lineSpacingExtra="2dp"
        android:textColor="?attr/mzMuted"
        android:textSize="14sp" />

    <LinearLayout
        android:id="@+id/achievementDetailsDiscoveryBlock"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="22dp"
        android:background="@drawable/bg_card_soft"
        android:orientation="vertical"
        android:padding="14dp">

        <TextView
            android:id="@+id/achievementDetailsDate"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="?attr/mzText"
            android:textSize="12sp" />

        <TextView
            android:id="@+id/achievementDetailsCode"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="5dp"
            android:fontFamily="monospace"
            android:textColor="?attr/mzMuted"
            android:textSize="11sp" />
    </LinearLayout>
</LinearLayout>
