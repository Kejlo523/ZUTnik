<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:paddingStart="20dp"
    android:paddingEnd="12dp"
    android:paddingTop="2dp"
    android:paddingBottom="4dp">

    <TextView
        android:id="@+id/tvPlanToolbarTitle"
        style="@style/TextAppearance.ZUTnik.Toolbar.Title"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/plan_title"
        android:textColor="?attr/mzText" />

    <TextView
        android:id="@+id/tvPlanToolbarSubtitle"
        style="@style/TextAppearance.ZUTnik.Toolbar.Subtitle"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="1dp"
        android:textColor="?attr/mzMuted" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="2dp"
        android:gravity="center_vertical"
        android:orientation="horizontal">

        <TextView
            android:id="@+id/tvHeaderLabel"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:ellipsize="end"
            android:maxLines="1"
            android:text="@string/common_dash"
            android:fontFamily="sans-serif-condensed"
            android:textColor="?attr/mzText"
            android:textSize="18sp"
            android:textStyle="bold" />

        <ImageButton
            android:id="@+id/btnSearch"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:layout_marginEnd="2dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="@string/plan_search_dialog_title"
            android:padding="5dp"
            android:scaleType="fitCenter"
            android:src="@drawable/ic_search"
            app:tint="?attr/mzText" />

        <ImageButton
            android:id="@+id/btnRefresh"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:layout_marginEnd="2dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="@string/plan_button_refresh"
            android:padding="5dp"
            android:scaleType="fitCenter"
            android:src="@drawable/ic_refresh"
            app:tint="?attr/mzText" />

        <ImageButton
            android:id="@+id/btnMenu"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="@string/plan_actions_label"
            android:padding="5dp"
            android:scaleType="fitCenter"
            android:src="@drawable/ic_more_vert"
            app:tint="?attr/mzText" />
    </LinearLayout>
</LinearLayout>
