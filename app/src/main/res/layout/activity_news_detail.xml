<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:orientation="vertical"
    android:background="@drawable/bg_app"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fitsSystemWindows="true">

    <!-- TOOLBAR -->
    <androidx.appcompat.widget.Toolbar
        android:id="@+id/toolbarDetail"
        android:layout_width="match_parent"
        android:layout_height="?attr/actionBarSize"
        android:background="@drawable/bg_toolbar"
        android:titleTextColor="@color/mz_text"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:elevation="0dp" />

    <!-- TREŚĆ -->
    <LinearLayout
        android:orientation="vertical"
        android:padding="16dp"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <!-- Mały pill / meta -->
        <TextView
            android:id="@+id/tvNewsDetailTag"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/news_detail_tag"
            android:textSize="11sp"
            android:textColor="@color/mz_primary"
            android:paddingStart="12dp"
            android:paddingEnd="12dp"
            android:paddingTop="6dp"
            android:paddingBottom="6dp"
            android:background="@drawable/bg_card_soft" />

        <!-- KARTA Z TYTUŁEM I METADANYMI -->
        <LinearLayout
            android:orientation="vertical"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:background="@drawable/bg_card_soft"
            android:padding="12dp">

            <TextView
                android:id="@+id/tvNewsDetailTitle"
                android:textColor="@color/mz_text"
                android:textSize="18sp"
                android:textStyle="bold"
                android:layout_width="match_parent"
                android:layout_height="wrap_content" />

            <TextView
                android:id="@+id/tvNewsDetailDate"
                android:textColor="@color/mz_muted"
                android:textSize="11sp"
                android:layout_marginTop="4dp"
                android:layout_width="match_parent"
                android:layout_height="wrap_content" />

            <TextView
                android:id="@+id/tvNewsDetailSource"
                android:textColor="@color/mz_primary"
                android:textSize="11sp"
                android:layout_marginTop="2dp"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content" />
        </LinearLayout>

        <!-- fallback tekstowy, gdy nie ma contentHtml -->
        <TextView
            android:id="@+id/tvNewsDetailFallback"
            android:textColor="@color/mz_text"
            android:textSize="13sp"
            android:layout_marginTop="12dp"
            android:visibility="gone"
            android:layout_width="match_parent"
            android:layout_height="wrap_content" />

        <!-- HTML z RSS – WebView wypełnia resztę ekranu -->
        <WebView
            android:id="@+id/webNewsDetail"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:layout_marginTop="12dp"
            android:background="@android:color/transparent" />

    </LinearLayout>

</LinearLayout>
