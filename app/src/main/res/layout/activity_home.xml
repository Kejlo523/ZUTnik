<?xml version="1.0" encoding="utf-8"?>
<androidx.drawerlayout.widget.DrawerLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/drawerLayout"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_app"
    android:fitsSystemWindows="true"
    app:statusBarBackground="@color/mz_bg">

    <!-- GŁÓWNA ZAWARTOŚĆ EKRANU -->
    <LinearLayout
        android:id="@+id/drawerContentRoot"
        android:orientation="vertical"
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <!-- TOOLBAR U GÓRY -->
        <androidx.appcompat.widget.Toolbar
            android:id="@+id/toolbar"
            android:layout_width="match_parent"
            android:layout_height="?attr/actionBarSize"
            android:background="@drawable/bg_toolbar"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:elevation="0dp"
            android:titleTextColor="@color/mz_text"
            android:theme="@style/ThemeOverlay.AppCompat.Dark.ActionBar" />

        <!-- TREŚĆ EKRANU -->
        <ScrollView
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:background="@android:color/transparent"
            android:overScrollMode="ifContentScrolls">

            <LinearLayout
                android:orientation="vertical"
                android:padding="16dp"
                android:layout_width="match_parent"
                android:layout_height="wrap_content">

                <!-- HERO / POWITANIE -->
                <LinearLayout
                    android:id="@+id/homeHero"
                    android:orientation="vertical"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="@drawable/bg_card_soft"
                    android:padding="16dp">

                    <TextView
                        android:id="@+id/textHeroPill"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:paddingStart="12dp"
                        android:paddingEnd="12dp"
                        android:paddingTop="4dp"
                        android:paddingBottom="4dp"
                        android:background="@drawable/bg_card_primary"
                        android:text="mZUT v2"
                        android:textColor="@color/mz_text"
                        android:textSize="11sp" />

                    <TextView
                        android:id="@+id/textWelcome"
                        android:text="Witaj, Student 👋"
                        android:textSize="22sp"
                        android:textStyle="bold"
                        android:textColor="@color/mz_text"
                        android:layout_marginTop="10dp"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content" />

                    <TextView
                        android:id="@+id/textWelcomeSub"
                        android:text="Szybki dostęp do planu, ocen, informacji o studiach i aktualności z ZUT."
                        android:textSize="14sp"
                        android:textColor="@color/mz_muted"
                        android:layout_marginTop="6dp"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content" />

                    <!-- DWA GŁÓWNE PRZYCISKI -->
                    <LinearLayout
                        android:orientation="horizontal"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="14dp">

                        <TextView
                            android:id="@+id/btnHeroPlan"
                            android:layout_width="0dp"
                            android:layout_height="40dp"
                            android:layout_weight="1"
                            android:gravity="center"
                            android:text="📅 Plan zajęć"
                            android:textSize="14sp"
                            android:textColor="@color/mz_text"
                            android:background="@drawable/bg_card_primary"
                            android:clickable="true"
                            android:focusable="true"
                            android:foreground="?attr/selectableItemBackground" />

                        <Space
                            android:layout_width="8dp"
                            android:layout_height="1dp" />

                        <TextView
                            android:id="@+id/btnHeroGrades"
                            android:layout_width="0dp"
                            android:layout_height="40dp"
                            android:layout_weight="1"
                            android:gravity="center"
                            android:text="⭐ Oceny"
                            android:textSize="14sp"
                            android:textColor="@color/mz_text"
                            android:background="@drawable/bg_card_soft"
                            android:clickable="true"
                            android:focusable="true"
                            android:foreground="?attr/selectableItemBackground" />
                    </LinearLayout>
                </LinearLayout>

                <!-- PRZERWA -->
                <Space
                    android:layout_width="match_parent"
                    android:layout_height="16dp" />

                <!-- SKRÓTY (LISTA KAFELKÓW) -->
                <LinearLayout
                    android:id="@+id/homeShortcuts"
                    android:orientation="vertical"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Szybkie skróty"
                        android:textColor="@color/mz_text"
                        android:textStyle="bold"
                        android:textSize="14sp"
                        android:layout_marginBottom="8dp" />

                    <!-- PLAN -->
                    <LinearLayout
                        android:id="@+id/tilePlan"
                        android:orientation="vertical"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:background="@drawable/bg_card_primary"
                        android:padding="14dp"
                        android:layout_marginBottom="8dp"
                        android:clickable="true"
                        android:focusable="true"
                        android:foreground="?attr/selectableItemBackground">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="📅 Plan zajęć"
                            android:textColor="@color/mz_text"
                            android:textStyle="bold"
                            android:textSize="15sp" />

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="Widok dnia, tygodnia i miesiąca + filtrowanie przedmiotów."
                            android:textColor="@color/mz_muted"
                            android:textSize="12sp"
                            android:layout_marginTop="3dp" />
                    </LinearLayout>

                    <!-- OCENY -->
                    <LinearLayout
                        android:id="@+id/tileGrades"
                        android:orientation="vertical"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:background="@drawable/bg_card_soft"
                        android:padding="14dp"
                        android:layout_marginBottom="8dp"
                        android:clickable="true"
                        android:focusable="true"
                        android:foreground="?attr/selectableItemBackground">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="⭐ Oceny"
                            android:textColor="@color/mz_text"
                            android:textStyle="bold"
                            android:textSize="15sp" />

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="Średnia, ECTS i szczegóły zaliczeń w jednym miejscu."
                            android:textColor="@color/mz_muted"
                            android:textSize="12sp"
                            android:layout_marginTop="3dp" />
                    </LinearLayout>

                    <!-- INFORMACJE -->
                    <LinearLayout
                        android:id="@+id/tileInfo"
                        android:orientation="vertical"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:background="@drawable/bg_card_soft"
                        android:padding="14dp"
                        android:layout_marginBottom="8dp"
                        android:clickable="true"
                        android:focusable="true"
                        android:foreground="?attr/selectableItemBackground">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="🎓 Informacje o studiach"
                            android:textColor="@color/mz_text"
                            android:textStyle="bold"
                            android:textSize="15sp" />

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="Kierunek, wydział, status studenta, przebieg studiów."
                            android:textColor="@color/mz_muted"
                            android:textSize="12sp"
                            android:layout_marginTop="3dp" />
                    </LinearLayout>

                    <!-- NEWS -->
                    <LinearLayout
                        android:id="@+id/tileNews"
                        android:orientation="vertical"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:background="@drawable/bg_card_soft"
                        android:padding="14dp"
                        android:layout_marginBottom="8dp"
                        android:clickable="true"
                        android:focusable="true"
                        android:foreground="?attr/selectableItemBackground">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="📰 Aktualności ZUT"
                            android:textColor="@color/mz_text"
                            android:textStyle="bold"
                            android:textSize="15sp" />

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="Komunikaty i ogłoszenia z kanału RSS dla studentów."
                            android:textColor="@color/mz_muted"
                            android:textSize="12sp"
                            android:layout_marginTop="3dp" />
                    </LinearLayout>
                </LinearLayout>

                <!-- LEKKI FOOTER / PODPOWIEDŹ -->
                <LinearLayout
                    android:id="@+id/homeSection"
                    android:orientation="vertical"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:padding="12dp"
                    android:background="@drawable/bg_card_soft">

                    <TextView
                        android:id="@+id/textFooterMeta"
                        android:text="Dane są pobierane z systemów ZUT i cache’owane lokalnie. Jeśli coś wygląda podejrzanie, zawsze zweryfikuj też w oficjalnych panelach."
                        android:textSize="11sp"
                        android:textColor="@color/mz_muted"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content" />
                </LinearLayout>

            </LinearLayout>
        </ScrollView>

    </LinearLayout>

    <!-- NAVIGATION DRAWER -->
    <com.google.android.material.navigation.NavigationView
        android:id="@+id/navigationView"
        android:layout_width="wrap_content"
        android:layout_height="match_parent"
        android:layout_gravity="start"
        android:background="@color/mz_bg"
        android:fitsSystemWindows="true">

        <include
            layout="@layout/nav_header"
            android:layout_width="match_parent"
            android:layout_height="match_parent" />

    </com.google.android.material.navigation.NavigationView>

</androidx.drawerlayout.widget.DrawerLayout>
