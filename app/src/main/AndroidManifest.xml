<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <uses-permission android:name="android.permission.INTERNET" />

    <application
        android:allowBackup="true"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:fullBackupContent="@xml/backup_rules"
        android:icon="@mipmap/ic_zut_logo"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_zut_logo_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.MZUTv2"
        tools:targetApi="31">

        <!-- 🔥 To jest ekran startowy -->
        <activity android:name=".LoginActivity"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <activity android:name=".HomeActivity" />

        <activity android:name=".InfoActivity" />

        <activity android:name=".GradesActivity" />

        <activity android:name=".NewsActivity" />

        <activity android:name=".NewsDetailActivity" />

        <activity android:name=".PlanActivity" />

        <activity
            android:name=".AboutActivity"
            android:label="O aplikacji" />

        <receiver
            android:name=".PlanDayWidgetProvider"
            android:exported="false">
            <intent-filter>
                <action android:name="android.appwidget.action.APPWIDGET_UPDATE" />
                <action android:name="pl.kejlo.mzutv2.PLAN_WIDGET_REFRESH" />
            </intent-filter>

            <meta-data
                android:name="android.appwidget.provider"
                android:resource="@xml/widget_plan_day_info" />
        </receiver>



    </application>

</manifest>
