<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/widgetRoot"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_widget_dark_glass"
    android:orientation="vertical"
    android:paddingStart="12dp"
    android:paddingEnd="12dp"
    android:paddingTop="8dp"
    android:paddingBottom="8dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:orientation="horizontal">

        <TextView
                android:id="@+id/widgetDate"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:includeFontPadding="false"
                android:text="@string/plan_widget_label_today"
                android:textColor="@color/glass_text_primary"
                android:textSize="15sp"
            android:textStyle="bold"
            android:shadowColor="#80000000"
            android:shadowDx="1"
            android:shadowDy="1"
            android:shadowRadius="1"/>

        <FrameLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content">

            <ImageView
                android:id="@+id/widgetRefresh"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:contentDescription="@string/plan_widget_refresh_desc"
                android:padding="4dp"
                android:src="@android:drawable/ic_popup_sync"
                app:tint="@color/glass_text_secondary" />

            <ProgressBar
                android:id="@+id/widgetLoading"
                style="?android:attr/progressBarStyleSmall"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:padding="4dp"
                android:indeterminate="true"
                android:indeterminateTint="@color/glass_text_secondary"
                android:visibility="gone" />
        </FrameLayout>
    </LinearLayout>

    <LinearLayout
        android:id="@+id/widgetStatusRow"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="1dp"
        android:layout_marginBottom="5dp"
        android:gravity="center_vertical"
        android:orientation="horizontal">

        <ImageView
            android:id="@+id/widgetStatusDot"
            android:layout_width="6dp"
            android:layout_height="6dp"
            android:layout_marginEnd="6dp"
            android:background="@drawable/bg_widget_status_dot"
            android:contentDescription="@null" />

        <TextView
            android:id="@+id/widgetSubtitle"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:ellipsize="end"
            android:includeFontPadding="false"
            android:maxLines="1"
            android:text="@string/plan_widget_subtitle_today"
            android:textColor="@color/glass_text_secondary"
            android:textSize="10sp" />
    </LinearLayout>

    <ListView
        android:id="@+id/widgetList"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:divider="@android:color/transparent"
        android:dividerHeight="4dp"
        android:paddingTop="0dp"
        android:paddingBottom="0dp"
        android:scrollbars="none" />

    <TextView
        android:id="@+id/widgetEmptyState"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:gravity="center"
        android:text="@string/plan_widget_empty_state"
        android:textColor="@color/glass_text_secondary"
        android:textSize="12sp"
        android:visibility="gone" />

    <TextView
        android:id="@+id/widgetLastRefresh"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="3dp"
        android:alpha="0.7"
        android:gravity="end"
        android:text="@string/plan_widget_refreshed_placeholder"
        android:textColor="@color/glass_text_secondary"
        android:includeFontPadding="false"
        android:textSize="9sp" />

</LinearLayout>
