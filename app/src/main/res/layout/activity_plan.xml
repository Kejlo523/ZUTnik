<?xml version="1.0" encoding="utf-8"?>
<androidx.drawerlayout.widget.DrawerLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/drawerLayout"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/mz_bg"
    android:fitsSystemWindows="true"
    app:statusBarBackground="@color/mz_bg">

    <!-- GŁÓWNA ZAWARTOŚĆ EKRANU -->
    <LinearLayout
        android:orientation="vertical"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fitsSystemWindows="true">

        <!-- TOOLBAR -->
        <androidx.appcompat.widget.Toolbar
            android:id="@+id/toolbar"
            android:layout_width="match_parent"
            android:layout_height="?attr/actionBarSize"
            android:background="@color/mz_bg"
            android:popupTheme="@style/ThemeOverlay.AppCompat.Dark" />

        <!-- GÓRNY PASEK: LUPA + ODŚWIEŻ | DATA | MENU -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingStart="8dp"
            android:paddingEnd="8dp"
            android:paddingTop="4dp"
            android:paddingBottom="4dp">

            <!-- Kontener Lupy i Odświeżania -->
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <!-- Przycisk Lupy (Szukaj) -->
                <ImageButton
                    android:id="@+id/btnSearch"
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:src="@drawable/ic_search"
                    app:tint="@color/mz_text"
                    android:padding="8dp"
                    android:scaleType="fitCenter"
                    android:contentDescription="@string/plan_search_hint" />

                <!-- Przycisk Odśwież (Refresh) -->
                <ImageButton
                    android:id="@+id/btnRefresh"
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:src="@drawable/ic_refresh"
                    app:tint="@color/mz_text"
                    android:padding="8dp"
                    android:scaleType="fitCenter"
                    android:contentDescription="@string/plan_button_refresh" />
            </LinearLayout>

            <!-- Wyśrodkowana Data -->
            <TextView
                android:id="@+id/tvHeaderLabel"
                android:text="-"
                android:textSize="16sp"
                android:textStyle="bold"
                android:textColor="@color/mz_text"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:gravity="center"
                android:layout_marginStart="8dp"
                android:layout_marginEnd="8dp"/>

            <!-- Przycisk Menu (Trzy kropki) -->
            <ImageButton
                android:id="@+id/btnMenu"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:src="@drawable/ic_more_vert"
                app:tint="@color/mz_text"
                android:padding="8dp"
                android:scaleType="fitCenter"
                android:contentDescription="Opcje" />

        </LinearLayout>

        <!-- TREŚĆ PLANU -->
        <LinearLayout
            android:id="@+id/planContentRoot"
            android:orientation="vertical"
            android:paddingLeft="12dp"
            android:paddingRight="12dp"
            android:paddingBottom="12dp"
            android:layout_width="match_parent"
            android:layout_height="match_parent">

            <!-- PRZEŁĄCZNIK WIDOKÓW (Dzień / Tydzień / Miesiąc) -->
            <LinearLayout
                android:id="@+id/layoutViewModesRow"
                android:orientation="horizontal"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:paddingBottom="8dp">

                <Button
                    android:id="@+id/btnViewDay"
                    android:text="@string/plan_view_day"
                    android:textSize="13sp"
                    android:background="@drawable/bg_mode_button"
                    android:textColor="@color/mz_text"
                    android:layout_width="0dp"
                    android:layout_height="36dp"
                    android:layout_weight="1"
                    android:layout_marginRight="4dp"
                    android:textAllCaps="false" />

                <Button
                    android:id="@+id/btnViewWeek"
                    android:text="@string/plan_view_week"
                    android:textSize="13sp"
                    android:background="@drawable/bg_mode_button"
                    android:textColor="@color/mz_text"
                    android:layout_width="0dp"
                    android:layout_height="36dp"
                    android:layout_weight="1"
                    android:layout_marginLeft="2dp"
                    android:layout_marginRight="2dp"
                    android:textAllCaps="false" />

                <Button
                    android:id="@+id/btnViewMonth"
                    android:text="@string/plan_view_month"
                    android:textSize="13sp"
                    android:background="@drawable/bg_mode_button"
                    android:textColor="@color/mz_text"
                    android:layout_width="0dp"
                    android:layout_height="36dp"
                    android:layout_weight="1"
                    android:layout_marginLeft="4dp"
                    android:textAllCaps="false" />
            </LinearLayout>

            <!-- STICKY HEADER (DNI TYGODNIA) -->
            <LinearLayout
                android:id="@+id/layoutWeekHeadersFixed"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:visibility="gone"
                android:paddingTop="4dp"
                android:paddingBottom="4dp">

                <!-- Pusty widok nad kolumną godzin (36dp) -->
                <View
                    android:layout_width="36dp"
                    android:layout_height="match_parent" />

                <!-- Kontener na nagłówki dni -->
                <LinearLayout
                    android:id="@+id/layoutWeekHeadersRow"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="horizontal" />
            </LinearLayout>

            <!-- SCROLL NA PLAN -->
            <ScrollView
                android:id="@+id/scrollPlan"
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="1"
                android:fillViewport="true"
                android:scrollbars="vertical">

                <LinearLayout
                    android:id="@+id/planScrollContent"
                    android:orientation="vertical"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content">

                    <!-- WIDOK TYGODNIA / DNIA -->
                    <LinearLayout
                        android:id="@+id/layoutWeekRoot"
                        android:orientation="horizontal"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:background="@color/mz_bg">

                        <!-- Kolumna godzin -->
                        <LinearLayout
                            android:id="@+id/layoutTimeColumn"
                            android:orientation="vertical"
                            android:layout_width="36dp"
                            android:layout_height="wrap_content"
                            android:paddingRight="2dp" />

                        <!-- ViewPager2 z siatką zajęć -->
                        <androidx.viewpager2.widget.ViewPager2
                            android:id="@+id/planViewPager"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:overScrollMode="never" />

                    </LinearLayout>

                    <!-- WIDOK MIESIĄCA -->
                    <LinearLayout
                        android:id="@+id/layoutMonthRoot"
                        android:orientation="vertical"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:visibility="gone">

                        <LinearLayout
                            android:id="@+id/layoutMonthWeekdays"
                            android:orientation="horizontal"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:paddingTop="4dp"
                            android:paddingBottom="4dp" />

                        <GridLayout
                            android:id="@+id/gridMonth"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:columnCount="7"
                            android:useDefaultMargins="false" />
                    </LinearLayout>

                </LinearLayout>
            </ScrollView>

            <!-- BRAK ZAJĘĆ -->
            <TextView
                android:id="@+id/tvEmpty"
                android:text="@string/plan_no_classes_in_range"
                android:textColor="@color/mz_muted"
                android:textSize="13sp"
                android:gravity="center"
                android:visibility="gone"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:paddingTop="6dp"
                android:paddingBottom="6dp" />

            <!-- PROGRESS -->
            <ProgressBar
                android:id="@+id/planProgress"
                style="?android:attr/progressBarStyleLarge"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:visibility="gone"
                android:indeterminate="true" />

        </LinearLayout>

    </LinearLayout>

    <!-- NAVIGATION DRAWER -->
    <com.google.android.material.navigation.NavigationView
        android:id="@+id/navigationView"
        android:layout_width="wrap_content"
        android:layout_height="match_parent"
        android:layout_gravity="start"
        android:background="@color/mz_bg"
        android:fitsSystemWindows="true">

        <include
            layout="@layout/nav_header"
            android:layout_width="match_parent"
            android:layout_height="match_parent" />

    </com.google.android.material.navigation.NavigationView>

</androidx.drawerlayout.widget.DrawerLayout>