<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <com.google.android.material.card.MaterialCardView
        android:id="@+id/cardContent"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_margin="3dp"
        android:clickable="true"
        android:focusable="true"
        android:foreground="?attr/selectableItemBackground"
        app:cardBackgroundColor="?attr/mzCard"
        app:cardCornerRadius="8dp"
        app:cardElevation="0dp"
        app:strokeColor="?attr/mzBorderSoft"
        app:strokeWidth="1dp">

        <LinearLayout
            android:id="@+id/contentContainer"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:gravity="start|center_vertical"
            android:orientation="vertical"
            android:padding="14dp">

            <ImageView
                android:id="@+id/iconView"
                android:layout_width="26dp"
                android:layout_height="26dp"
                android:layout_marginBottom="10dp"
                android:contentDescription="@null"
                android:importantForAccessibility="no"
                android:src="@drawable/ic_zut_logo_inapp"
                app:tint="?attr/mzPrimary" />

            <TextView
                android:id="@+id/textTitle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:ellipsize="end"
                android:fontFamily="sans-serif-condensed"
                android:maxLines="3"
                android:textColor="?attr/mzText"
                android:textSize="17sp"
                android:textStyle="bold"
                tools:text="Plan zajęć" />

            <TextView
                android:id="@+id/textDesc"
                style="@style/TextAppearance.ZUTnik.Label"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:ellipsize="end"
                android:maxLines="2"
                tools:text="Widok dnia i tygodnia" />
        </LinearLayout>

        <View
            android:id="@+id/editBorder"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="@drawable/bg_tile_edit_border"
            android:visibility="gone" />
    </com.google.android.material.card.MaterialCardView>

    <ImageView
        android:id="@+id/btnDelete"
        android:layout_width="28dp"
        android:layout_height="28dp"
        android:layout_gravity="top|end"
        android:background="@drawable/bg_circle_soft"
        android:backgroundTint="?attr/mzDanger"
        android:elevation="4dp"
        android:padding="6dp"
        android:src="@android:drawable/ic_menu_close_clear_cancel"
        android:visibility="gone"
        app:tint="@android:color/white" />

    <ImageView
        android:id="@+id/btnDrag"
        android:layout_width="28dp"
        android:layout_height="28dp"
        android:layout_gravity="top|start"
        android:background="@drawable/bg_circle_soft"
        android:backgroundTint="?attr/mzPrimary"
        android:elevation="4dp"
        android:padding="6dp"
        android:src="@drawable/ic_drag_handle"
        android:visibility="gone"
        app:tint="?attr/colorOnPrimary" />

    <ImageView
        android:id="@+id/btnResizeRight"
        android:layout_width="28dp"
        android:layout_height="28dp"
        android:layout_gravity="bottom|end"
        android:layout_margin="2dp"
        android:background="@drawable/bg_circle_soft"
        android:backgroundTint="?attr/mzCard"
        android:elevation="4dp"
        android:padding="5dp"
        android:src="@drawable/ic_tile_resize_br"
        android:visibility="gone"
        app:tint="?attr/mzPrimary" />

    <ImageView
        android:id="@+id/btnResizeLeft"
        android:layout_width="28dp"
        android:layout_height="28dp"
        android:layout_gravity="bottom|start"
        android:layout_margin="2dp"
        android:background="@drawable/bg_circle_soft"
        android:backgroundTint="?attr/mzCard"
        android:elevation="4dp"
        android:padding="5dp"
        android:src="@drawable/ic_tile_resize_bl"
        android:visibility="gone"
        app:tint="?attr/mzPrimary" />
</FrameLayout>
