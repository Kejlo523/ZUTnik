<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:padding="18dp"
    android:fillViewport="false"
    android:overScrollMode="ifContentScrolls">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginBottom="12dp">

        <TextView
            android:id="@+id/textTitle"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="@string/plan_quick_dialog_title_add"
            android:textColor="?attr/mzText"
            android:textSize="18sp"
            android:textStyle="bold" />

        <ImageButton
            android:id="@+id/btnClose"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:src="@drawable/ic_close"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="@string/plan_quick_btn_cancel"
            app:tint="?attr/mzMuted" />
    </LinearLayout>

    <LinearLayout
        android:id="@+id/detailsContainer"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="@drawable/bg_card_soft"
        android:padding="12dp"
        android:layout_marginBottom="12dp"
        android:visibility="gone">

        <TextView
            android:id="@+id/textDetailsTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/plan_quick_details_title"
            android:textColor="?attr/mzText"
            android:textSize="12sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/textDetails"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:textColor="?attr/mzMuted"
            android:textSize="12sp" />

        <LinearLayout
            android:id="@+id/typeRow"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:visibility="gone">

            <TextView
                android:id="@+id/textTypeLabel"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/plan_type_label"
                android:textColor="?attr/mzMuted"
                android:textSize="12sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/textTypeChip"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:background="@drawable/bg_grade_type_chip"
                android:paddingHorizontal="10dp"
                android:paddingVertical="4dp"
                android:textColor="?attr/mzPrimary"
                android:textSize="12sp"
                android:textStyle="bold"
                tools:text="Laboratorium" />
        </LinearLayout>
    </LinearLayout>

    <com.google.android.material.textfield.TextInputLayout
        android:id="@+id/inputSubjectLayout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="4dp"
        android:hint="@string/plan_quick_subject_label"
        app:placeholderText="@string/plan_quick_subject_hint"
        app:placeholderTextColor="?attr/mzMuted"
        app:endIconMode="dropdown_menu"
        app:boxBackgroundMode="outline"
        app:boxStrokeColor="?attr/mzPrimary"
        app:boxStrokeWidth="1dp"
        app:boxStrokeWidthFocused="2dp"
        app:boxCornerRadiusTopStart="12dp"
        app:boxCornerRadiusTopEnd="12dp"
        app:boxCornerRadiusBottomStart="12dp"
        app:boxCornerRadiusBottomEnd="12dp"
        app:boxBackgroundColor="?attr/mzInputBg"
        app:hintTextColor="?attr/mzMuted">

        <AutoCompleteTextView
            android:id="@+id/editSubject"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:inputType="text"
            android:gravity="center_vertical|start"
            android:minHeight="48dp"
            android:paddingStart="12dp"
            android:paddingEnd="12dp"
            android:paddingTop="12dp"
            android:paddingBottom="12dp"
            android:textSize="15sp"
            android:textColor="?attr/mzText" />
    </com.google.android.material.textfield.TextInputLayout>

    <TextView
        android:id="@+id/labelType"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:text="@string/plan_quick_type_label"
        android:textColor="?attr/mzText"
        android:textSize="12sp"
        android:textStyle="bold" />

    <com.google.android.material.chip.ChipGroup
        android:id="@+id/chipGroupType"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="6dp"
        app:singleSelection="true"
        app:chipSpacingHorizontal="8dp"
        app:chipSpacingVertical="6dp"
        app:selectionRequired="true">

        <com.google.android.material.chip.Chip
            android:id="@+id/chipExam"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/plan_custom_type_exam"
            android:checkable="true"
            android:textColor="?attr/mzPrimary"
            app:checkedIconVisible="false"
            app:chipStrokeWidth="1dp"
            app:chipStrokeColor="?attr/mzPrimary"
            app:chipBackgroundColor="@color/chip_bg_primary" />

        <com.google.android.material.chip.Chip
            android:id="@+id/chipPass"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/plan_custom_type_pass"
            android:checkable="true"
            android:textColor="?attr/mzPrimary"
            app:checkedIconVisible="false"
            app:chipStrokeWidth="1dp"
            app:chipStrokeColor="?attr/mzPrimary"
            app:chipBackgroundColor="@color/chip_bg_primary" />

        <com.google.android.material.chip.Chip
            android:id="@+id/chipTest"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/plan_custom_type_test"
            android:checkable="true"
            android:textColor="?attr/mzPrimary"
            app:checkedIconVisible="false"
            app:chipStrokeWidth="1dp"
            app:chipStrokeColor="?attr/mzPrimary"
            app:chipBackgroundColor="@color/chip_bg_primary" />
    </com.google.android.material.chip.ChipGroup>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:orientation="horizontal">

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/plan_quick_date_label"
                android:textColor="?attr/mzMuted"
                android:textSize="11sp" />

            <TextView
                android:id="@+id/textDate"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:background="?attr/selectableItemBackground"
                android:padding="6dp"
                android:textColor="?attr/mzText"
                android:textSize="14sp" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/plan_quick_time_label"
                android:textColor="?attr/mzMuted"
                android:textSize="11sp" />

            <TextView
                android:id="@+id/textTime"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:background="?attr/selectableItemBackground"
                android:padding="6dp"
                android:textColor="?attr/mzText"
                android:textSize="14sp" />
        </LinearLayout>
    </LinearLayout>

    <com.google.android.material.textfield.TextInputLayout
        android:id="@+id/inputNotesLayout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:hint="@string/plan_quick_notes_label"
        app:placeholderText="@string/plan_quick_notes_hint"
        app:placeholderTextColor="?attr/mzMuted"
        app:boxBackgroundMode="outline"
        app:boxStrokeColor="?attr/mzPrimary"
        app:boxStrokeWidth="1dp"
        app:boxStrokeWidthFocused="2dp"
        app:boxCornerRadiusTopStart="12dp"
        app:boxCornerRadiusTopEnd="12dp"
        app:boxCornerRadiusBottomStart="12dp"
        app:boxCornerRadiusBottomEnd="12dp"
        app:boxBackgroundColor="?attr/mzInputBg"
        app:hintTextColor="?attr/mzMuted">

        <com.google.android.material.textfield.TextInputEditText
            android:id="@+id/editNotes"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:inputType="textMultiLine"
            android:gravity="top|start"
            android:minLines="2"
            android:paddingStart="12dp"
            android:paddingEnd="12dp"
            android:paddingTop="10dp"
            android:paddingBottom="10dp"
            android:textColor="?attr/mzText" />
    </com.google.android.material.textfield.TextInputLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:orientation="vertical">

        <Button
            android:id="@+id/btnDelete"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/plan_custom_remove_marker"
            android:textColor="?attr/mzDanger"
            style="?android:attr/borderlessButtonStyle"
            android:layout_gravity="start"
            android:visibility="gone" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="end"
            android:layout_marginTop="4dp">

            <Button
                android:id="@+id/btnCancel"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/plan_quick_btn_cancel"
                android:textColor="?attr/mzMuted"
                style="?android:attr/borderlessButtonStyle" />

            <Button
                android:id="@+id/btnSave"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/plan_quick_btn_save"
                android:textColor="@android:color/white"
                android:backgroundTint="?attr/mzPrimary"
                android:layout_marginStart="8dp" />
        </LinearLayout>
    </LinearLayout>

    </LinearLayout>
</androidx.core.widget.NestedScrollView>
