<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/mainShellRoot"
    android:orientation="vertical"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_landscape_canvas"
    android:fitsSystemWindows="false"
    app:statusBarBackground="?attr/mzBg">

    <FrameLayout
        android:id="@+id/drawerContentRoot"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical">

            <androidx.appcompat.widget.Toolbar
                android:id="@+id/toolbar"
                android:layout_width="match_parent"
                android:layout_height="?attr/actionBarSize"
                android:background="@drawable/bg_toolbar"
                android:elevation="0dp"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:titleTextColor="?attr/mzNavHeaderText" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:baselineAligned="false"
                android:orientation="horizontal"
                android:padding="16dp">

                <ScrollView
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="0.35"
                    android:contentDescription="@string/home_side_panel_desc"
                    android:fillViewport="true"
                    android:layout_marginEnd="16dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="center_vertical"
                        android:orientation="vertical"
                        android:padding="16dp"
                        android:background="@drawable/bg_landscape_panel">

                        <LinearLayout
                            android:id="@+id/homeHero"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:background="@drawable/bg_card_soft"
                            android:gravity="center_horizontal"
                            android:orientation="vertical"
                            android:paddingStart="16dp"
                            android:paddingTop="12dp"
                            android:paddingEnd="16dp"
                            android:paddingBottom="12dp">

                            <TextView
                                android:id="@+id/textHeroPill"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:background="@drawable/bg_card_soft"
                                android:letterSpacing="0.05"
                                android:paddingStart="8dp"
                                android:paddingTop="3dp"
                                android:paddingEnd="8dp"
                                android:paddingBottom="3dp"
                                android:text="@string/app_name"
                                android:textAllCaps="true"
                                android:textColor="?attr/mzText"
                                android:textSize="9sp"
                                android:textStyle="bold" />

                            <TextView
                                android:id="@+id/textWelcome"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="8dp"
                                android:gravity="center"
                                android:text="@string/home_welcome_fallback"
                                android:textColor="?attr/mzText"
                                android:textSize="18sp"
                                android:textStyle="bold" />

                            <TextView
                                android:id="@+id/textWelcomeSub"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="4dp"
                                android:gravity="center"
                                android:text="@string/home_welcome_subtitle"
                                android:textColor="?attr/mzMuted"
                                android:textSize="11sp" />
                        </LinearLayout>

                        <Space
                            android:layout_width="match_parent"
                            android:layout_height="24dp" />

                        <LinearLayout
                            android:id="@+id/homeSection"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:background="@drawable/bg_card_soft"
                            android:gravity="center"
                            android:padding="16dp">
                            <TextView
                                android:id="@+id/textFooterMeta"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:gravity="center"
                                android:text="@string/home_footer_meta"
                                android:textColor="?attr/mzMuted"
                                android:textSize="11sp" />
                        </LinearLayout>

                    </LinearLayout>
                </ScrollView>

                <ScrollView
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="0.65"
                    android:clipToPadding="false"
                    android:padding="16dp"
                    android:background="@drawable/bg_landscape_panel"
                    android:scrollbars="vertical">

                    <LinearLayout
                        android:id="@+id/homeShortcuts"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginBottom="16dp"
                            android:text="@string/home_shortcuts_title"
                            android:textColor="?attr/mzText"
                            android:textSize="18sp"
                            android:textStyle="bold" />

                        <pl.kejlo.zutnik.TileGridLayout
                            android:id="@+id/tileGrid"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_gravity="center_horizontal"
                            android:layout_marginBottom="16dp" />
                    </LinearLayout>
                </ScrollView>
            </LinearLayout>
        </LinearLayout>

        <!-- Indicator Overlay (Bottom Left) -->
        <androidx.cardview.widget.CardView
            android:id="@+id/indicatorOverlay"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:layout_gravity="bottom|start"
            android:layout_margin="24dp"
            app:cardCornerRadius="24dp"
            app:cardElevation="6dp"
            app:cardBackgroundColor="?attr/mzPrimary"
            android:visibility="gone">

            <ImageView
                android:id="@+id/indicatorIcon"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:layout_gravity="center"
                android:src="@drawable/ic_check"
                app:tint="?attr/colorOnPrimary" />
        </androidx.cardview.widget.CardView>

    </FrameLayout>
    <include layout="@layout/include_bottom_navigation" />
</LinearLayout>
