<?xml version="1.0" encoding="utf-8"?>
<androidx.drawerlayout.widget.DrawerLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/drawerLayout"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_app"
    android:fitsSystemWindows="true"
    app:statusBarBackground="@color/mz_bg">

    <LinearLayout
        android:orientation="vertical"
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <androidx.appcompat.widget.Toolbar
            android:id="@+id/toolbar"
            android:layout_width="match_parent"
            android:layout_height="?attr/actionBarSize"
            android:background="@drawable/bg_toolbar"
            android:titleTextColor="@color/mz_text"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:elevation="0dp" />

        <LinearLayout
            android:orientation="horizontal"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:baselineAligned="false">

            <ScrollView
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="0.35"
                android:fillViewport="true"
                android:background="@color/mz_bg">

                <LinearLayout
                    android:orientation="vertical"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:padding="24dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginBottom="16dp">
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/grades_header_pill"
                            android:textSize="11sp"
                            android:textColor="@color/mz_primary"
                            android:paddingStart="12dp"
                            android:paddingEnd="12dp"
                            android:paddingTop="6dp"
                            android:paddingBottom="6dp"
                            android:background="@drawable/bg_card_soft" />
                        <Space android:layout_width="0dp" android:layout_height="1dp" android:layout_weight="1"/>
                        <ImageView
                            android:id="@+id/btnGradesRefresh"
                            android:layout_width="28dp"
                            android:layout_height="28dp"
                            android:src="@android:drawable/ic_popup_sync"
                            app:tint="@color/mz_muted"
                            android:clickable="true"
                            android:focusable="true"/>
                    </LinearLayout>

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="@string/grades_hero_title"
                        android:textColor="@color/mz_text"
                        android:textStyle="bold"
                        android:textSize="22sp"
                        android:layout_marginBottom="24dp" />

                    <LinearLayout
                        android:orientation="vertical"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:background="@drawable/bg_card_primary"
                        android:padding="20dp"
                        android:layout_marginBottom="24dp">

                        <TextView
                            android:text="@string/grades_summary_average_label"
                            android:textColor="@color/mz_muted"
                            android:textSize="12sp"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content" />
                        <TextView
                            android:id="@+id/tvAverageValue"
                            android:text="@string/grades_average_placeholder"
                            android:textColor="@color/mz_text"
                            android:textSize="32sp"
                            android:textStyle="bold"
                            android:layout_marginBottom="16dp"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content" />

                        <View android:layout_width="match_parent" android:layout_height="1dp" android:background="@color/mz_border_soft" android:layout_marginBottom="16dp"/>

                        <TextView
                            android:text="@string/grades_summary_ects_label"
                            android:textColor="@color/mz_muted"
                            android:textSize="12sp"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content" />
                        <TextView
                            android:id="@+id/tvEctsValue"
                            android:text="0"
                            android:textColor="@color/mz_text"
                            android:textSize="32sp"
                            android:textStyle="bold"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content" />
                    </LinearLayout>

                    <TextView
                        android:text="@string/grades_study_label"
                        android:textColor="@color/mz_text"
                        android:textSize="12sp"
                        android:textStyle="bold"
                        android:layout_marginBottom="4dp"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content" />
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:background="@drawable/bg_card_soft"
                        android:padding="4dp"
                        android:layout_marginBottom="16dp">
                        <Spinner
                            android:id="@+id/spinnerStudies"
                            android:layout_width="match_parent"
                            android:layout_height="40dp"
                            android:background="@android:color/transparent"
                            android:spinnerMode="dropdown" />
                    </LinearLayout>

                    <TextView
                        android:text="@string/grades_semester_caption"
                        android:textColor="@color/mz_text"
                        android:textSize="12sp"
                        android:textStyle="bold"
                        android:layout_marginBottom="4dp"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content" />
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:background="@drawable/bg_card_soft"
                        android:padding="4dp">
                        <Spinner
                            android:id="@+id/spinnerSemesters"
                            android:layout_width="match_parent"
                            android:layout_height="40dp"
                            android:background="@android:color/transparent"
                            android:spinnerMode="dropdown" />
                    </LinearLayout>

                </LinearLayout>
            </ScrollView>

            <LinearLayout
                android:orientation="vertical"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="0.65"
                android:padding="16dp">

                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/listGrades"
                    android:layout_width="match_parent"
                    android:layout_height="0dp"
                    android:layout_weight="1"
                    android:clipToPadding="false"
                    android:paddingBottom="16dp"
                    android:overScrollMode="ifContentScrolls" />

                <ProgressBar
                    android:id="@+id/gradesProgress"
                    style="?android:attr/progressBarStyle"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center"
                    android:visibility="gone" />

                <TextView
                    android:id="@+id/tvEmpty"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/grades_empty_state"
                    android:textColor="@color/mz_muted"
                    android:textSize="14sp"
                    android:gravity="center"
                    android:layout_gravity="center"
                    android:visibility="gone" />

            </LinearLayout>

        </LinearLayout>
    </LinearLayout>

    <com.google.android.material.navigation.NavigationView
        android:id="@+id/navigationView"
        android:layout_width="wrap_content"
        android:layout_height="match_parent"
        android:layout_gravity="start"
        android:background="@color/mz_bg"
        android:fitsSystemWindows="true">
        <include layout="@layout/nav_header" />
    </com.google.android.material.navigation.NavigationView>

</androidx.drawerlayout.widget.DrawerLayout>