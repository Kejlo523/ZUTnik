<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:foreground="?attr/selectableItemBackground">

    <!-- Main Content Card -->
    <androidx.cardview.widget.CardView
        android:id="@+id/cardContent"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_margin="10dp"
        app:cardCornerRadius="16dp"
        app:cardElevation="0dp"
        app:cardBackgroundColor="?attr/mzBgSurface"
        xmlns:app="http://schemas.android.com/apk/res-auto">

        <LinearLayout
            android:id="@+id/contentContainer"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical"
            android:gravity="center"
            android:padding="12dp">

            <ImageView
                android:id="@+id/iconView"
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:layout_gravity="center"
                android:src="@drawable/ic_zut_logo_inapp"
                android:visibility="gone"
                app:tint="?attr/mzPrimary" />

            <TextView
                android:id="@+id/textTitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="?attr/mzText"
                android:textSize="16sp"
                android:textStyle="bold"
                android:maxLines="2"
                android:ellipsize="end"
                tools:text="Title" />

            <TextView
                android:id="@+id/textDesc"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:textColor="?attr/mzMuted"
                android:textSize="12sp"
                android:maxLines="3"
                android:ellipsize="end"
                tools:text="Description" />
        </LinearLayout>
        
        <!-- Edit Border Overlay (inside card) -->
        <View
            android:id="@+id/editBorder"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="@drawable/bg_tile_edit_border"
            android:visibility="gone" />
            
    </androidx.cardview.widget.CardView>

    <!-- Floating Delete Button (Top Right) -->
    <ImageView
        android:id="@+id/btnDelete"
        android:layout_width="28dp"
        android:layout_height="28dp"
        android:layout_gravity="top|end"
        android:layout_margin="0dp"
        android:src="@android:drawable/ic_menu_close_clear_cancel"
        android:background="@drawable/bg_circle_soft"
        android:backgroundTint="?attr/mzDanger"
        android:elevation="4dp"
        android:padding="6dp"
        android:visibility="gone"
        app:tint="@android:color/white"
        xmlns:app="http://schemas.android.com/apk/res-auto"/>

    <!-- Drag Handle (Top Left) -->
    <ImageView
        android:id="@+id/btnDrag"
        android:layout_width="28dp"
        android:layout_height="28dp"
        android:layout_gravity="top|start"
        android:layout_margin="0dp"
        android:src="@drawable/ic_drag_handle"
        android:background="@drawable/bg_circle_soft"
        android:backgroundTint="?attr/mzPrimary"
        android:elevation="4dp"
        android:padding="6dp"
        android:visibility="gone"
        app:tint="?attr/colorOnPrimary"
        xmlns:app="http://schemas.android.com/apk/res-auto"/>

    <!-- Resize Handle Right (Bottom Right) -->
    <ImageView
        android:id="@+id/btnResizeRight"
        android:layout_width="28dp"
        android:layout_height="28dp"
        android:layout_gravity="bottom|end"
        android:layout_margin="2dp"
        android:background="@drawable/bg_circle_soft"
        android:backgroundTint="?attr/mzCard"
        android:contentDescription="@null"
        android:elevation="4dp"
        android:padding="5dp"
        android:src="@drawable/ic_tile_resize_br"
        android:visibility="gone"
        app:tint="?attr/mzPrimary"
        xmlns:app="http://schemas.android.com/apk/res-auto" />

    <!-- Resize Handle Left (Bottom Left) -->
    <ImageView
        android:id="@+id/btnResizeLeft"
        android:layout_width="28dp"
        android:layout_height="28dp"
        android:layout_gravity="bottom|start"
        android:layout_margin="2dp"
        android:background="@drawable/bg_circle_soft"
        android:backgroundTint="?attr/mzCard"
        android:contentDescription="@null"
        android:elevation="4dp"
        android:padding="5dp"
        android:src="@drawable/ic_tile_resize_bl"
        android:visibility="gone"
        app:tint="?attr/mzPrimary"
        xmlns:app="http://schemas.android.com/apk/res-auto" />

</FrameLayout>
