<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="24dp"
    android:background="@drawable/dialog_background_rounded"
    >

    <ImageView
        android:layout_width="48dp"
        android:layout_height="48dp"
        android:src="@drawable/ic_battery_alert"
        android:layout_marginBottom="16dp"
        android:layout_gravity="center_horizontal"
        android:tint="@color/mz_primary"
        />

    <TextView
        android:id="@+id/tvTitle"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/battery_opt_dialog_title"
        android:textSize="20sp"
        android:textStyle="bold"
        android:textColor="@color/mz_text"
        android:gravity="center"
        android:layout_marginBottom="12dp"
        />

    <TextView
        android:id="@+id/tvMessage"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/battery_opt_dialog_message"
        android:textColor="@color/mz_text"
        android:textSize="16sp"
        android:lineSpacingMultiplier="1.2"
        android:gravity="center"
        android:layout_marginBottom="24dp"
        />

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnSettings"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/battery_opt_button_settings"
        android:backgroundTint="@color/mz_primary"
        android:textColor="@color/mz_bg"
        android:layout_marginBottom="8dp"
        android:paddingTop="12dp"
        android:paddingBottom="12dp"
        />

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnCancel"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/battery_opt_button_cancel"
        android:backgroundTint="@android:color/transparent"
        android:textColor="@color/mz_muted"
        style="@style/Widget.MaterialComponents.Button.TextButton"
        />

</LinearLayout>
