<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:state_pressed="true">
        <shape>
            <solid android:color="?attr/mzCard" />
            <stroke android:width="2dp" android:color="?attr/mzPrimary" />
            <corners android:radius="8dp" />
        </shape>
    </item>
    <item>
        <shape>
            <solid android:color="?attr/mzBgSurface" />
            <stroke android:width="1dp" android:color="?attr/mzBorderStrong" />
            <corners android:radius="8dp" />
        </shape>
    </item>
</selector>
