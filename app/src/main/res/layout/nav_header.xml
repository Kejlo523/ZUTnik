<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/navHeaderRoot"
    android:orientation="vertical"
    android:paddingStart="16dp"
    android:paddingEnd="16dp"
    android:paddingTop="48dp"
    android:paddingBottom="20dp"
    android:background="?attr/mzBg"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <!-- BLOK GÓRNY: tytuł + użytkownik + linki (zajmuje całą resztę miejsca) -->
    <LinearLayout
        android:id="@+id/navTopBlock"
        android:orientation="vertical"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content">

            <ImageView
                android:id="@+id/navHeaderIcon"
                android:layout_width="46dp"
                android:layout_height="46dp"
                android:layout_marginBottom="20dp"
                android:clipToOutline="true"
                android:scaleType="centerCrop"
                android:layout_marginLeft="5dp"
                android:src="@mipmap/ic_zut_logo_round" />
        </LinearLayout>

        <LinearLayout
            android:orientation="vertical"
            android:layout_width="match_parent"
            android:gravity="center_vertical"
            android:layout_marginLeft="5dp"
            android:layout_height="wrap_content">

            <TextView
                android:id="@+id/navHeaderTitle"
                android:text="@string/app_name"
                android:textSize="20sp"
                android:textStyle="bold"
                android:fontFamily="sans-serif-medium"
                android:textColor="?attr/mzText"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content" />

            <TextView
                android:id="@+id/navHeaderUser"
                android:text="@string/nav_header_default_username"
                android:textSize="12sp"
                android:fontFamily="sans-serif"
                android:textColor="?attr/mzMuted"
                android:layout_marginTop="2dp"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content" />
        </LinearLayout>

        <!-- separator nad linkami -->
        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:layout_marginTop="16dp"
            android:background="?attr/mzBorderSoft" />

        <!-- LINKI -->
        <LinearLayout
            android:orientation="vertical"
            android:layout_marginTop="12dp"
            android:layout_width="match_parent"
            android:layout_height="wrap_content">

            <TextView
                android:id="@+id/navLinkHome"
                android:text="@string/home_title"
                android:textSize="14sp"
                android:fontFamily="sans-serif-medium"
                android:textColor="?attr/mzText"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:paddingTop="10dp"
                android:paddingBottom="10dp"
                android:layout_marginTop="4dp"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_nav_item"
                android:gravity="center_vertical"
                android:clickable="true"
                android:focusable="true"
                android:foreground="?attr/selectableItemBackground" />

            <TextView
                android:id="@+id/navLinkPlan"
                android:text="@string/plan_title"
                android:textSize="14sp"
                android:fontFamily="sans-serif-medium"
                android:textColor="?attr/mzText"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:paddingTop="10dp"
                android:paddingBottom="10dp"
                android:layout_marginTop="6dp"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_nav_item"
                android:gravity="center_vertical"
                android:clickable="true"
                android:focusable="true"
                android:foreground="?attr/selectableItemBackground" />

            <TextView
                android:id="@+id/navLinkGrades"
                android:text="@string/grades_title"
                android:textSize="14sp"
                android:fontFamily="sans-serif-medium"
                android:textColor="?attr/mzText"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:paddingTop="10dp"
                android:paddingBottom="10dp"
                android:layout_marginTop="6dp"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_nav_item"
                android:gravity="center_vertical"
                android:clickable="true"
                android:focusable="true"
                android:foreground="?attr/selectableItemBackground" />

            <TextView
                android:id="@+id/navLinkAttendance"
                android:text="@string/attendance_title"
                android:textSize="14sp"
                android:fontFamily="sans-serif-medium"
                android:textColor="?attr/mzText"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:paddingTop="10dp"
                android:paddingBottom="10dp"
                android:layout_marginTop="6dp"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_nav_item"
                android:gravity="center_vertical"
                android:clickable="true"
                android:focusable="true"
                android:foreground="?attr/selectableItemBackground" />

            <TextView
                android:id="@+id/navLinkInfo"
                android:text="@string/info_title"
                android:textSize="14sp"
                android:fontFamily="sans-serif-medium"
                android:textColor="?attr/mzText"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:paddingTop="10dp"
                android:paddingBottom="10dp"
                android:layout_marginTop="6dp"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_nav_item"
                android:gravity="center_vertical"
                android:clickable="true"
                android:focusable="true"
                android:foreground="?attr/selectableItemBackground" />

            <TextView
                android:id="@+id/navLinkNews"
                android:text="@string/news_title"
                android:textSize="14sp"
                android:fontFamily="sans-serif-medium"
                android:textColor="?attr/mzText"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:paddingTop="10dp"
                android:paddingBottom="10dp"
                android:layout_marginTop="6dp"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_nav_item"
                android:gravity="center_vertical"
                android:clickable="true"
                android:focusable="true"
                android:foreground="?attr/selectableItemBackground" />

            <TextView
                android:id="@+id/navLinkUsefull"
                android:text="@string/nav_useful_links"
                android:textSize="14sp"
                android:fontFamily="sans-serif-medium"
                android:textColor="?attr/mzText"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:paddingTop="10dp"
                android:paddingBottom="10dp"
                android:layout_marginTop="6dp"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_nav_item"
                android:gravity="center_vertical"
                android:clickable="true"
                android:focusable="true"
                android:foreground="?attr/selectableItemBackground" />

            <TextView
                android:id="@+id/navLinkAbout"
                android:text="@string/about_title"
                android:textSize="14sp"
                android:fontFamily="sans-serif-medium"
                android:textColor="?attr/mzText"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:paddingTop="10dp"
                android:paddingBottom="10dp"
                android:layout_marginTop="6dp"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_nav_item"
                android:gravity="center_vertical"
                android:clickable="true"
                android:focusable="true"
                android:foreground="?attr/selectableItemBackground" />
        </LinearLayout>
    </LinearLayout>

    <!-- DÓŁ: wersja + zębatka ustawień -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="16dp"
        android:layout_marginBottom="5dp"
        android:paddingEnd="16dp">

        <TextView
            android:id="@+id/navAppVersion"
            android:text="@string/app_version"
            android:textSize="12sp"
            android:fontFamily="sans-serif"
            android:textColor="?attr/mzMuted"
            android:paddingTop="6dp"
            android:paddingBottom="6dp"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1" />

        <ImageView
            android:id="@+id/navWatch"
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:layout_marginEnd="6dp"
            android:padding="4dp"
            android:src="@drawable/ic_watch_24"
            android:contentDescription="@string/nav_watch_label"
            android:clickable="true"
            android:focusable="true"
            android:background="@drawable/bg_nav_item"
            android:foreground="?attr/selectableItemBackgroundBorderless"
            app:tint="?attr/mzText" />

        <ImageView
            android:id="@+id/navSettings"
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:padding="4dp"
            android:src="@drawable/ic_settings_24"
            android:contentDescription="@string/nav_settings_label"
            android:clickable="true"
            android:focusable="true"
            android:background="@drawable/bg_nav_item"
            android:foreground="?attr/selectableItemBackgroundBorderless"
            app:tint="?attr/mzText" />
    </LinearLayout>

    <!-- separator nad wylogowaniem -->
    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:layout_marginBottom="8dp"
        android:background="?attr/mzBorderSoft" />

    <!-- DÓŁ: wyloguj -->
    <TextView
        android:id="@+id/navLogout"
        android:text="@string/nav_logout_label"
        android:textSize="14sp"
        android:fontFamily="sans-serif-medium"
        android:textColor="?attr/mzDanger"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:paddingTop="10dp"
        android:paddingBottom="10dp"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_horizontal"
        android:clickable="true"
        android:focusable="true"
        android:background="@drawable/bg_nav_logout"
        android:foreground="?attr/selectableItemBackground" />

</LinearLayout>
