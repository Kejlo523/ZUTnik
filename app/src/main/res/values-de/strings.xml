    <string name="about_title">Über die App</string>

    <string name="about_subtitle">
        Inoffizielle mobile App für ZUT-Studenten, mit Stundenplan, Noten, Studieninformationen und Tageswidget — ohne Werbung und Tracking.
    </string>

    <string name="about_section_project_title">Projekt und Autor</string>
    <string name="about_author_line">Der Autor der App ist Jędrzej Nowak.</string>
    <string name="about_project_description_1">
        mZUT v2 wurde als inoffizielle, leichte Alternative erstellt, um Stundenplan, Noten und Studieninformationen schnell einzusehen.
    </string>
    <string name="about_project_description_2">
        Die App nutzt öffentlich verfügbare Systeme und APIs der Universität. Anmeldedaten bleiben auf Ihrem Gerät.
    </string>

    <string name="about_section_contact_title">Kontakt und Links</string>
    <string name="about_contact_email">E-mail: kejlo@endozero.pl</string>
    <string name="about_contact_website">Webseite: endozero.pl</string>
    <string name="about_contact_app_website">App-Webseite: mzut.endozero.pl</string>
    <string name="about_contact_github">GitHub: https://github.com/Kejlo523/mzut-v2</string>

    <string name="about_section_privacy_title">Datenschutz</string>
    <string name="about_privacy_text_1">
        mZUT v2 verwendet keine externen Analysesysteme, zeigt keine Werbung und verfolgt Ihre Aktivitäten nicht.
    </string>
    <string name="about_privacy_text_2">
        Anmeldedaten werden nur zur Authentifizierung in den Universitätssystemen verwendet und lokal gespeichert.
    </string>

    <string name="about_footer_disclaimer">
        mZUT v2 ist ein inoffizielles Projekt und keine offizielle App der Westpommerschen Technischen Universität.
    </string>

