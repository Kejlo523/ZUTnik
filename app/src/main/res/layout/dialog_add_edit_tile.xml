<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:clipToPadding="false"
    android:fillViewport="true"
    android:scrollbars="none">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingStart="20dp"
        android:paddingTop="8dp"
        android:paddingEnd="20dp"
        android:paddingBottom="12dp">

        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="@dimen/tile_editor_preview_height"
            android:layout_marginBottom="18dp"
            android:background="@drawable/bg_tile_preview_surface"
            android:padding="10dp">

            <pl.kejlo.zutnik.TileView
                android:id="@+id/tileEditorPreview"
                android:layout_width="@dimen/tile_editor_tile_width"
                android:layout_height="@dimen/tile_editor_tile_height"
                android:layout_gravity="center" />
        </FrameLayout>

        <TextView
            style="@style/TextAppearance.ZUTnik.Label"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="7dp"
            android:labelFor="@id/etTitle"
            android:text="@string/dialog_add_edit_tile_label_title" />

        <com.google.android.material.textfield.TextInputLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:boxBackgroundColor="?attr/mzInputBg"
            app:boxBackgroundMode="outline"
            app:boxCornerRadiusBottomEnd="7dp"
            app:boxCornerRadiusBottomStart="7dp"
            app:boxCornerRadiusTopEnd="7dp"
            app:boxCornerRadiusTopStart="7dp"
            app:counterEnabled="true"
            app:counterMaxLength="40"
            app:hintEnabled="false"
            app:hintTextColor="?attr/mzMuted">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/etTitle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="@string/dialog_add_edit_tile_hint_title"
                android:inputType="textCapSentences"
                android:maxLength="40"
                android:minHeight="52dp"
                android:maxLines="2" />
        </com.google.android.material.textfield.TextInputLayout>

        <TextView
            style="@style/TextAppearance.ZUTnik.Label"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="14dp"
            android:layout_marginBottom="7dp"
            android:labelFor="@id/etDesc"
            android:text="@string/dialog_add_edit_tile_label_desc" />

        <com.google.android.material.textfield.TextInputLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:boxBackgroundColor="?attr/mzInputBg"
            app:boxBackgroundMode="outline"
            app:boxCornerRadiusBottomEnd="7dp"
            app:boxCornerRadiusBottomStart="7dp"
            app:boxCornerRadiusTopEnd="7dp"
            app:boxCornerRadiusTopStart="7dp"
            app:counterEnabled="true"
            app:counterMaxLength="90"
            app:hintEnabled="false"
            app:hintTextColor="?attr/mzMuted">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/etDesc"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="@string/dialog_add_edit_tile_hint_desc"
                android:inputType="textCapSentences|textMultiLine"
                android:maxLength="90"
                android:minHeight="52dp"
                android:maxLines="3" />
        </com.google.android.material.textfield.TextInputLayout>

        <TextView
            style="@style/TextAppearance.ZUTnik.Label"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="18dp"
            android:layout_marginBottom="7dp"
            android:text="@string/dialog_add_edit_tile_label_action" />

        <Spinner
            android:id="@+id/spinnerAction"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:background="@drawable/bg_spinner_dark"
            android:popupBackground="?attr/mzCard"
            android:spinnerMode="dropdown" />

        <LinearLayout
            android:id="@+id/containerUrl"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:orientation="vertical"
            android:visibility="gone">

            <TextView
                style="@style/TextAppearance.ZUTnik.Label"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="7dp"
                android:labelFor="@id/etUrl"
                android:text="@string/dialog_add_edit_tile_label_url_section" />

            <com.google.android.material.textfield.TextInputLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:boxBackgroundColor="?attr/mzInputBg"
                app:boxBackgroundMode="outline"
                app:hintEnabled="false"
                app:hintTextColor="?attr/mzMuted">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/etUrl"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="@string/dialog_add_edit_tile_hint_url"
                    android:inputType="textUri"
                    android:minHeight="52dp"
                    android:maxLines="2" />
            </com.google.android.material.textfield.TextInputLayout>
        </LinearLayout>

        <LinearLayout
            android:id="@+id/containerSavedParams"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:orientation="vertical"
            android:visibility="gone">

            <TextView
                style="@style/TextAppearance.ZUTnik.Label"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="7dp"
                android:text="@string/dialog_add_edit_tile_label_saved_search" />

            <Spinner
                android:id="@+id/spinnerSavedParams"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:background="@drawable/bg_spinner_dark"
                android:popupBackground="?attr/mzCard"
                android:spinnerMode="dropdown" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="18dp"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <TextView
                style="@style/TextAppearance.ZUTnik.Label"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="@string/dialog_add_edit_tile_label_color" />

            <TextView
                android:id="@+id/btnColorDefault"
                android:layout_width="wrap_content"
                android:layout_height="40dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:gravity="center"
                android:paddingStart="10dp"
                android:paddingEnd="10dp"
                android:text="@string/dialog_add_edit_tile_color_default"
                android:textColor="?attr/mzPrimary"
                android:textSize="12sp" />
        </LinearLayout>

        <HorizontalScrollView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:scrollbars="none">

            <LinearLayout
                android:id="@+id/containerColors"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal" />
        </HorizontalScrollView>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnColorCustom"
            style="@style/Widget.Material3.Button.TextButton"
            android:layout_width="wrap_content"
            android:layout_height="42dp"
            android:layout_gravity="end"
            android:layout_marginTop="2dp"
            android:minWidth="0dp"
            android:text="@string/dialog_add_edit_tile_color_custom"
            android:textColor="?attr/mzMuted" />

        <LinearLayout
            android:id="@+id/containerColorMixer"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_tile_preview_surface"
            android:orientation="vertical"
            android:padding="12dp"
            android:visibility="gone">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <View
                    android:id="@+id/colorPreview"
                    android:layout_width="32dp"
                    android:layout_height="32dp" />

                <TextView
                    style="@style/TextAppearance.ZUTnik.Label"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="10dp"
                    android:text="@string/dialog_add_edit_tile_color_custom" />
            </LinearLayout>

            <TextView
                style="@style/TextAppearance.ZUTnik.Label"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:text="@string/dialog_add_edit_tile_color_hue" />

            <SeekBar
                android:id="@+id/seekHue"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:max="360"
                android:progressTint="?attr/mzPrimary"
                android:thumbTint="?attr/mzPrimary" />

            <TextView
                style="@style/TextAppearance.ZUTnik.Label"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/dialog_add_edit_tile_color_sat" />

            <SeekBar
                android:id="@+id/seekSat"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:max="100"
                android:progressTint="?attr/mzPrimary"
                android:thumbTint="?attr/mzPrimary" />

            <TextView
                style="@style/TextAppearance.ZUTnik.Label"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/dialog_add_edit_tile_color_val" />

            <SeekBar
                android:id="@+id/seekVal"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:max="100"
                android:progressTint="?attr/mzPrimary"
                android:thumbTint="?attr/mzPrimary" />
        </LinearLayout>
    </LinearLayout>
</ScrollView>
