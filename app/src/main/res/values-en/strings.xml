    <string name="about_title">About the app</string>

    <string name="about_subtitle">
        Unofficial mobile app for ZUT students, with timetable, grades, study information and a daily widget — without ads and tracking.
    </string>

    <string name="about_section_project_title">Project and author</string>
    <string name="about_author_line">The app was created by Jędrzej Nowak.</string>
    <string name="about_project_description_1">
        mZUT v2 was created as an unofficial, lightweight alternative for quickly viewing timetable, grades and study information at ZUT, without having to click through heavy web panels.
    </string>
    <string name="about_project_description_2">
        The app uses publicly available university systems and APIs, and login data stays on your device.
    </string>

    <string name="about_section_contact_title">Contact and links</string>
    <string name="about_contact_email">E-mail: kejlo@endozero.pl</string>
    <string name="about_contact_website">Website: endozero.pl</string>
    <string name="about_contact_app_website">App website: mzut.endozero.pl</string>
    <string name="about_contact_github">GitHub: https://github.com/Kejlo523/mzut-v2</string>

    <string name="about_section_privacy_title">Privacy and data</string>
    <string name="about_privacy_text_1">
        mZUT v2 does not use external analytics systems (Google Analytics, Firebase Analytics etc.), does not show ads and does not track your activity in the app.
    </string>
    <string name="about_privacy_text_2">
        Login data is only used to authenticate in university systems and is stored locally on the device. No data is sent to the app author\'s servers.
    </string>

    <string name="about_footer_disclaimer">
        mZUT v2 is an unofficial project and is not an app released by the West Pomeranian University of Technology.
    </string>

