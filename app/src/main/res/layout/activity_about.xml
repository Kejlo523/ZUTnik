<?xml version="1.0" encoding="utf-8"?>
<androidx.drawerlayout.widget.DrawerLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/drawerLayout"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_app"
    android:fitsSystemWindows="true"
    app:statusBarBackground="@color/mz_bg">

    <!-- GŁÓWNA ZAWARTOŚĆ EKRANU -->
    <LinearLayout
        android:orientation="vertical"
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <!-- TOOLBAR -->
        <androidx.appcompat.widget.Toolbar
            android:id="@+id/toolbar"
            android:layout_width="match_parent"
            android:layout_height="?attr/actionBarSize"
            android:background="@drawable/bg_toolbar"
            android:titleTextColor="@color/mz_text"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:elevation="0dp" />

        <!-- CONTENT POD TOOLBAREM -->
        <ScrollView
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:overScrollMode="ifContentScrolls">

            <LinearLayout
                android:orientation="vertical"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:padding="16dp">

                <!-- HERO / nagłówek ekranu -->
                <LinearLayout
                    android:orientation="vertical"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:paddingBottom="20dp">

                    <!-- mały pill -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:paddingStart="12dp"
                        android:paddingEnd="12dp"
                        android:paddingTop="6dp"
                        android:paddingBottom="6dp"
                        android:background="@drawable/bg_card_soft"
                        android:text="@string/about_header_pill"
                        android:textColor="@color/mz_primary"
                        android:textSize="11sp" />

                    <!-- aboutTitle -->
                    <TextView
                        android:id="@+id/aboutTitle"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="@string/app_name"
                        android:textSize="22sp"
                        android:textStyle="bold"
                        android:textColor="@color/mz_text"
                        android:layout_marginTop="10dp" />

                    <!-- aboutSubtitle -->
                    <TextView
                        android:id="@+id/aboutSubtitle"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="@string/about_subtitle"
                        android:textSize="14sp"
                        android:textColor="@color/mz_muted"
                        android:layout_marginTop="6dp" />
                </LinearLayout>

                <!-- KARTA: projekt i autor -->
                <LinearLayout
                    android:orientation="vertical"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="@drawable/bg_card_soft"
                    android:padding="16dp"
                    android:layout_marginBottom="12dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/about_section_project_title"
                        android:textSize="14sp"
                        android:textStyle="bold"
                        android:textColor="@color/mz_text"
                        android:layout_marginBottom="6dp" />

                    <!-- wyraźna linijka z autorem -->
                    <TextView
                        android:id="@+id/aboutAuthor"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/about_author_line"
                        android:textSize="13sp"
                        android:textColor="@color/mz_primary"
                        android:layout_marginBottom="6dp" />

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="@string/about_project_description_1"
                        android:textSize="13sp"
                        android:textColor="@color/mz_muted"
                        android:layout_marginBottom="6dp" />

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="@string/about_project_description_2"
                        android:textSize="13sp"
                        android:textColor="@color/mz_muted" />
                </LinearLayout>

                <!-- KARTA: kontakt i linki -->
                <LinearLayout
                    android:orientation="vertical"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="@drawable/bg_card_soft"
                    android:padding="16dp"
                    android:layout_marginBottom="12dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/about_section_contact_title"
                        android:textSize="14sp"
                        android:textStyle="bold"
                        android:textColor="@color/mz_text"
                        android:layout_marginBottom="8dp" />

                    <!-- Email -->
                    <TextView
                        android:id="@+id/aboutEmail"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/about_contact_email"
                        android:textColor="@color/mz_primary"
                        android:textSize="13sp"
                        android:autoLink="email"
                        android:layout_marginBottom="4dp" />

                    <!-- Strona ogólna -->
                    <TextView
                        android:id="@+id/aboutWebsite"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/about_contact_website"
                        android:textColor="@color/mz_primary"
                        android:textSize="13sp"
                        android:autoLink="web"
                        android:layout_marginBottom="4dp" />

                    <!-- Strona aplikacji -->
                    <TextView
                        android:id="@+id/aboutAppPage"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/about_contact_app_website"
                        android:textColor="@color/mz_primary"
                        android:textSize="13sp"
                        android:autoLink="web"
                        android:layout_marginBottom="4dp" />

                    <!-- GitHub -->
                    <TextView
                        android:id="@+id/aboutGithub"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/about_contact_github"
                        android:textColor="@color/mz_primary"
                        android:textSize="13sp"
                        android:autoLink="web" />
                </LinearLayout>

                <!-- KARTA: prywatność i dane -->
                <LinearLayout
                    android:orientation="vertical"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="@drawable/bg_card_soft"
                    android:padding="16dp"
                    android:layout_marginBottom="12dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/about_section_privacy_title"
                        android:textSize="14sp"
                        android:textStyle="bold"
                        android:textColor="@color/mz_text"
                        android:layout_marginBottom="6dp" />

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="@string/about_privacy_text_1"
                        android:textSize="13sp"
                        android:textColor="@color/mz_muted"
                        android:layout_marginBottom="6dp" />

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="@string/about_privacy_text_2"
                        android:textSize="13sp"
                        android:textColor="@color/mz_muted" />
                </LinearLayout>

                <!-- drobna stopka -->
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/about_footer_disclaimer"
                    android:textSize="11sp"
                    android:textColor="@color/mz_muted"
                    android:layout_marginTop="4dp"
                    android:layout_marginBottom="8dp" />

            </LinearLayout>
        </ScrollView>

    </LinearLayout>

    <!-- NAVIGATION DRAWER -->
    <com.google.android.material.navigation.NavigationView
        android:id="@+id/navigationView"
        android:layout_width="wrap_content"
        android:layout_height="match_parent"
        android:layout_gravity="start"
        android:background="@color/mz_bg"
        android:fitsSystemWindows="true">

        <include
            layout="@layout/nav_header"
            android:layout_width="match_parent"
            android:layout_height="match_parent" />

    </com.google.android.material.navigation.NavigationView>

</androidx.drawerlayout.widget.DrawerLayout>
