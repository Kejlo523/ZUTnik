<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/mainShellRoot"
    android:orientation="vertical"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="?attr/mzBg"
    android:fitsSystemWindows="false"
    app:statusBarBackground="?attr/mzBg">

    <FrameLayout
        android:id="@+id/drawerContentRoot"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical">

            <androidx.appcompat.widget.Toolbar
                android:id="@+id/toolbar"
                android:layout_width="match_parent"
                android:layout_height="?attr/actionBarSize"
                android:background="@drawable/bg_toolbar"
                android:elevation="0dp"
                android:paddingStart="20dp"
                android:paddingEnd="20dp"
                android:titleTextColor="?attr/mzNavHeaderText" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:baselineAligned="false"
                android:orientation="horizontal"
                android:padding="18dp">

                <ScrollView
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_marginEnd="14dp"
                    android:layout_weight="0.39"
                    android:clipToPadding="false"
                    android:fillViewport="true"
                    android:overScrollMode="ifContentScrolls"
                    android:paddingBottom="8dp"
                    android:scrollbars="none">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:background="@drawable/bg_tablet_surface"
                        android:orientation="vertical"
                        android:padding="18dp">

                        <LinearLayout
                            android:id="@+id/homeHero"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:background="@drawable/bg_tablet_surface_soft"
                            android:gravity="center_horizontal"
                            android:orientation="vertical"
                            android:paddingStart="18dp"
                            android:paddingTop="16dp"
                            android:paddingEnd="18dp"
                            android:paddingBottom="16dp">

                            <TextView
                                android:id="@+id/textHeroPill"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:background="@drawable/bg_tablet_chip"
                                android:letterSpacing="0.06"
                                android:paddingStart="10dp"
                                android:paddingTop="4dp"
                                android:paddingEnd="10dp"
                                android:paddingBottom="4dp"
                                android:text="@string/app_name"
                                android:textAllCaps="true"
                                android:textColor="?attr/mzPrimary"
                                android:textSize="10sp"
                                android:textStyle="bold" />

                            <TextView
                                android:id="@+id/textWelcome"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="12dp"
                                android:gravity="center"
                                android:text="@string/home_welcome_fallback"
                                android:textColor="?attr/mzText"
                                android:textSize="28sp"
                                android:textStyle="bold" />

                            <TextView
                                android:id="@+id/textWelcomeSub"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="6dp"
                                android:gravity="center"
                                android:text="@string/home_welcome_subtitle"
                                android:textColor="?attr/mzMuted"
                                android:textSize="14sp" />
                        </LinearLayout>

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="16dp"
                            android:layout_marginBottom="10dp"
                            android:text="@string/home_shortcuts_title"
                            android:textColor="?attr/mzText"
                            android:textSize="16sp"
                            android:textStyle="bold" />

                        <LinearLayout
                            android:id="@+id/homeSection"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:background="@drawable/bg_tablet_surface_soft"
                            android:orientation="vertical"
                            android:padding="14dp">

                            <TextView
                                android:id="@+id/textFooterMeta"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:gravity="center"
                                android:text="@string/home_footer_meta"
                                android:textColor="?attr/mzMuted"
                                android:textSize="12sp" />
                        </LinearLayout>
                    </LinearLayout>
                </ScrollView>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="0.61"
                    android:background="@drawable/bg_tablet_surface"
                    android:orientation="vertical"
                    android:paddingStart="18dp"
                    android:paddingTop="16dp"
                    android:paddingEnd="18dp"
                    android:paddingBottom="12dp">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="12dp"
                        android:text="@string/home_shortcuts_title"
                        android:textColor="?attr/mzText"
                        android:textSize="20sp"
                        android:textStyle="bold" />

                    <ScrollView
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:fillViewport="true"
                        android:overScrollMode="ifContentScrolls"
                        android:scrollbars="vertical">

                        <pl.kejlo.mzutv2.TileGridLayout
                            android:id="@+id/tileGrid"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content" />
                    </ScrollView>
                </LinearLayout>
            </LinearLayout>
        </LinearLayout>

        <androidx.cardview.widget.CardView
            android:id="@+id/indicatorOverlay"
            android:layout_width="52dp"
            android:layout_height="52dp"
            android:layout_gravity="bottom|start"
            android:layout_margin="24dp"
            android:visibility="gone"
            app:cardBackgroundColor="?attr/mzPrimary"
            app:cardCornerRadius="26dp"
            app:cardElevation="6dp">

            <ImageView
                android:id="@+id/indicatorIcon"
                android:layout_width="26dp"
                android:layout_height="26dp"
                android:layout_gravity="center"
                android:src="@drawable/ic_check"
                app:tint="?attr/colorOnPrimary" />
        </androidx.cardview.widget.CardView>

        <androidx.cardview.widget.CardView
            android:id="@+id/syncIndicator"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="bottom|center_horizontal"
            android:layout_marginBottom="24dp"
            android:visibility="gone"
            app:cardBackgroundColor="?attr/mzBgSurface"
            app:cardCornerRadius="20dp"
            app:cardElevation="6dp">

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:paddingStart="14dp"
                android:paddingTop="10dp"
                android:paddingEnd="16dp"
                android:paddingBottom="10dp">

                <ProgressBar
                    android:id="@+id/syncProgress"
                    android:layout_width="16dp"
                    android:layout_height="16dp"
                    android:indeterminate="true"
                    android:indeterminateTint="?attr/mzPrimary" />

                <ImageView
                    android:id="@+id/syncDoneIcon"
                    android:layout_width="16dp"
                    android:layout_height="16dp"
                    android:src="@drawable/ic_check"
                    android:visibility="gone"
                    app:tint="?attr/mzPrimary" />

                <TextView
                    android:id="@+id/syncText"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="10dp"
                    android:text="@string/wear_main_status_syncing"
                    android:textColor="?attr/mzText"
                    android:textSize="12sp"
                    android:textStyle="bold" />
            </LinearLayout>
        </androidx.cardview.widget.CardView>
    </FrameLayout>
    <include layout="@layout/include_bottom_navigation" />
</LinearLayout>
