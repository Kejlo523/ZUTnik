<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/homeEditDock"
    android:layout_width="match_parent"
    android:layout_height="72dp"
    android:layout_gravity="bottom"
    android:layout_marginStart="16dp"
    android:layout_marginEnd="16dp"
    android:layout_marginBottom="14dp"
    android:elevation="12dp"
    android:visibility="gone"
    app:cardBackgroundColor="?attr/mzCard"
    app:cardCornerRadius="8dp"
    app:cardElevation="10dp"
    app:strokeColor="?attr/mzBorderStrong"
    app:strokeWidth="1dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingStart="10dp"
        android:paddingEnd="10dp">

        <ImageButton
            android:id="@+id/btnHomeEditReset"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="@string/menu_home_reset"
            android:padding="13dp"
            android:src="@drawable/ic_refresh"
            app:tint="?attr/mzMuted" />

        <ImageButton
            android:id="@+id/btnHomeEditAdd"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:layout_marginStart="2dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="@string/menu_home_add"
            android:padding="12dp"
            android:src="@drawable/ic_plus"
            app:tint="?attr/mzPrimary" />

        <Space
            android:layout_width="0dp"
            android:layout_height="1dp"
            android:layout_weight="1" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnHomeEditCancel"
            style="@style/Widget.Material3.Button.TextButton"
            android:layout_width="82dp"
            android:layout_height="48dp"
            android:minHeight="48dp"
            android:minWidth="82dp"
            android:paddingStart="12dp"
            android:paddingEnd="12dp"
            android:text="@string/menu_home_cancel"
            android:textColor="?attr/mzText"
            android:textSize="15sp" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnHomeEditSave"
            style="@style/Widget.Material3.Button"
            android:layout_width="88dp"
            android:layout_height="48dp"
            android:layout_marginStart="4dp"
            android:minHeight="48dp"
            android:minWidth="88dp"
            android:paddingStart="14dp"
            android:paddingEnd="14dp"
            android:text="@string/menu_home_save"
            android:textColor="?attr/colorOnPrimary"
            android:textSize="15sp"
            app:backgroundTint="?attr/mzPrimary"
            app:cornerRadius="7dp" />
    </LinearLayout>
</com.google.android.material.card.MaterialCardView>
