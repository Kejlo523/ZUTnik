<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:clipToPadding="false"
    android:fillViewport="true"
    android:overScrollMode="never">

<LinearLayout
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:paddingStart="16dp"
    android:paddingTop="8dp"
    android:paddingEnd="16dp"
    android:paddingBottom="18dp">

    <View
        android:layout_width="44dp"
        android:layout_height="4dp"
        android:layout_gravity="center_horizontal"
        android:layout_marginBottom="14dp"
        android:background="@drawable/bg_sheet_handle" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingStart="4dp"
        android:paddingEnd="4dp"
        android:paddingBottom="12dp">

        <TextView
            style="@style/TextAppearance.ZUTnik.Display"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="@string/nav_tab_more"
            android:textColor="?attr/mzText"
            android:textSize="26sp" />

        <TextView
            android:id="@+id/moreAppVersion"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:ellipsize="end"
            android:maxLines="1"
            android:textColor="?attr/mzMuted"
            android:textSize="12sp" />
    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@android:color/transparent"
        android:orientation="vertical"
        android:paddingTop="4dp"
        android:paddingBottom="4dp">

        <LinearLayout
            android:id="@+id/moreLinkFinance"
            style="@style/MoreSheetRow"
            android:contentDescription="@string/finance_title">

            <FrameLayout style="@style/MoreSheetIconFrame">
                <ImageView
                    style="@style/MoreSheetIcon"
                    android:src="@drawable/ic_wallet" />
            </FrameLayout>

            <TextView
                style="@style/MoreSheetLabel"
                android:text="@string/finance_title" />

            <ImageView
                style="@style/MoreSheetChevron"
                android:src="@drawable/ic_chevron_right" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/moreLinkAttendance"
            style="@style/MoreSheetRow"
            android:contentDescription="@string/attendance_title">

            <FrameLayout style="@style/MoreSheetIconFrame">
                <ImageView
                    style="@style/MoreSheetIcon"
                    android:src="@drawable/ic_check" />
            </FrameLayout>

            <TextView
                style="@style/MoreSheetLabel"
                android:text="@string/attendance_title" />

            <ImageView
                style="@style/MoreSheetChevron"
                android:src="@drawable/ic_chevron_right" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/moreLinkNews"
            style="@style/MoreSheetRow"
            android:contentDescription="@string/news_title">

            <FrameLayout style="@style/MoreSheetIconFrame">
                <ImageView
                    style="@style/MoreSheetIcon"
                    android:src="@drawable/ic_newspaper" />
            </FrameLayout>

            <TextView
                style="@style/MoreSheetLabel"
                android:text="@string/news_title" />

            <ImageView
                style="@style/MoreSheetChevron"
                android:src="@drawable/ic_chevron_right" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/moreLinkUseful"
            style="@style/MoreSheetRow"
            android:contentDescription="@string/nav_useful_links">

            <FrameLayout style="@style/MoreSheetIconFrame">
                <ImageView
                    style="@style/MoreSheetIcon"
                    android:src="@drawable/ic_link" />
            </FrameLayout>

            <TextView
                style="@style/MoreSheetLabel"
                android:text="@string/nav_useful_links" />

            <ImageView
                style="@style/MoreSheetChevron"
                android:src="@drawable/ic_chevron_right" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/moreLinkAbout"
            style="@style/MoreSheetRow"
            android:contentDescription="@string/about_title">

            <FrameLayout style="@style/MoreSheetIconFrame">
                <ImageView
                    style="@style/MoreSheetIcon"
                    android:src="@drawable/ic_info" />
            </FrameLayout>

            <TextView
                style="@style/MoreSheetLabel"
                android:text="@string/about_title" />

            <ImageView
                style="@style/MoreSheetChevron"
                android:src="@drawable/ic_chevron_right" />
        </LinearLayout>
    </LinearLayout>

    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:layout_marginStart="44dp"
        android:layout_marginTop="8dp"
        android:layout_marginBottom="8dp"
        android:background="?attr/mzBorderSoft" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@android:color/transparent"
        android:orientation="vertical"
        android:paddingTop="4dp"
        android:paddingBottom="4dp">

        <LinearLayout
            android:id="@+id/moreLinkSettings"
            style="@style/MoreSheetRow"
            android:contentDescription="@string/nav_settings_label">

            <FrameLayout style="@style/MoreSheetIconFrame">
                <ImageView
                    style="@style/MoreSheetIcon"
                    android:src="@drawable/ic_settings_24" />
            </FrameLayout>

            <TextView
                style="@style/MoreSheetLabel"
                android:text="@string/nav_settings_label" />

            <ImageView
                style="@style/MoreSheetChevron"
                android:src="@drawable/ic_chevron_right" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/moreLinkLogout"
            style="@style/MoreSheetRow"
            android:contentDescription="@string/nav_logout_label">

            <FrameLayout style="@style/MoreSheetDangerIconFrame">
                <ImageView
                    style="@style/MoreSheetDangerIcon"
                    android:src="@drawable/ic_logout_24" />
            </FrameLayout>

            <TextView
                style="@style/MoreSheetDangerLabel"
                android:text="@string/nav_logout_label" />
        </LinearLayout>
    </LinearLayout>

</LinearLayout>
</androidx.core.widget.NestedScrollView>
