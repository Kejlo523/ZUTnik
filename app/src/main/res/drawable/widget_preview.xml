<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- Background: Card Soft -->
    <item>
        <shape android:shape="rectangle">
            <solid android:color="#F5F5F7" />
            <corners android:radius="16dp" />
        </shape>
    </item>

    <!-- Header Area -->
    <!-- Date: "Dziś" -->
    <item android:top="16dp" android:left="16dp" android:width="80dp" android:height="14dp">
        <shape android:shape="rectangle">
            <solid android:color="#4A4A4A" /> <!-- Dark Text -->
            <corners android:radius="4dp" />
        </shape>
    </item>
    
    <!-- Refresh Icon Placeholder (Top Right) -->
    <item android:top="14dp" android:right="16dp" android:width="20dp" android:height="20dp" android:gravity="top|end">
        <shape android:shape="oval">
            <stroke android:width="2dp" android:color="#B0B0B0" />
            <solid android:color="#00000000" />
        </shape>
    </item>

    <!-- Subtitle: "Dzisiejsze zajęcia" -->
    <item android:top="40dp" android:left="16dp" android:width="120dp" android:height="8dp">
         <shape android:shape="rectangle">
            <solid android:color="#9E9E9E" /> <!-- Muted Text -->
            <corners android:radius="2dp" />
        </shape>
    </item>

    <!-- Divider Line -->
    <item android:top="56dp" android:left="0dp" android:right="0dp" android:height="1dp">
        <shape android:shape="rectangle">
            <solid android:color="#E0E0E0" />
        </shape>
    </item>

    <!-- List Item 1 -->
    <!-- Time Column -->
    <item android:top="68dp" android:left="16dp" android:width="40dp" android:height="12dp">
        <shape android:shape="rectangle">
            <solid android:color="#4A4A4A" /> 
            <corners android:radius="2dp" />
        </shape>
    </item>
    
    <!-- Vertical Line Indicator -->
    <item android:top="68dp" android:left="64dp" android:width="2dp" android:height="32dp">
         <shape android:shape="rectangle">
            <solid android:color="#2196F3" /> <!-- Accent Color -->
        </shape>
    </item>

    <!-- Content Block -->
    <item android:top="68dp" android:left="74dp" android:right="16dp" android:height="32dp">
        <shape android:shape="rectangle">
            <solid android:color="#FFFFFF" />
            <corners android:radius="6dp" />
        </shape>
    </item>
    
    <!-- Subject Name inside block -->
    <item android:top="74dp" android:left="82dp" android:width="100dp" android:height="8dp">
         <shape android:shape="rectangle">
            <solid android:color="#E0E0E0" />
            <corners android:radius="2dp" />
        </shape>
    </item>
     <item android:top="86dp" android:left="82dp" android:width="60dp" android:height="6dp">
         <shape android:shape="rectangle">
            <solid android:color="#F0F0F0" />
            <corners android:radius="2dp" />
        </shape>
    </item>

    <!-- List Item 2 -->
    <!-- Time Column -->
    <item android:top="110dp" android:left="16dp" android:width="40dp" android:height="12dp">
        <shape android:shape="rectangle">
            <solid android:color="#9E9E9E" /> 
            <corners android:radius="2dp" />
        </shape>
    </item>
    
    <!-- Vertical Line Indicator -->
    <item android:top="110dp" android:left="64dp" android:width="2dp" android:height="32dp">
         <shape android:shape="rectangle">
            <solid android:color="#BDBDBD" /> 
        </shape>
    </item>

    <!-- Content Block -->
    <item android:top="110dp" android:left="74dp" android:right="16dp" android:height="32dp">
        <shape android:shape="rectangle">
            <solid android:color="#FFFFFF" />
            <corners android:radius="6dp" />
        </shape>
    </item>
     <!-- Subject Name inside block -->
    <item android:top="116dp" android:left="82dp" android:width="100dp" android:height="8dp">
         <shape android:shape="rectangle">
            <solid android:color="#E0E0E0" />
            <corners android:radius="2dp" />
        </shape>
    </item>
     <item android:top="128dp" android:left="82dp" android:width="60dp" android:height="6dp">
         <shape android:shape="rectangle">
            <solid android:color="#F0F0F0" />
            <corners android:radius="2dp" />
        </shape>
    </item>

    <!-- Bottom Refresh Text -->
    <item android:gravity="bottom|end" android:bottom="8dp" android:right="16dp" android:width="100dp" android:height="8dp">
         <shape android:shape="rectangle">
            <solid android:color="#B0B0B0" />
            <corners android:radius="2dp" />
        </shape>
    </item>

</layer-list>
