<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_app"
    android:overScrollMode="ifContentScrolls">

    <LinearLayout
        android:orientation="vertical"
        android:gravity="center_horizontal"
        android:padding="16dp"
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <!-- Ikona apki -->
        <ImageView
            android:id="@+id/appIcon"
            android:layout_width="72dp"
            android:layout_height="72dp"
            android:layout_marginTop="40dp"
            android:layout_marginBottom="12dp"
            android:src="@mipmap/ic_zut_logo_foreground"
            android:contentDescription="@string/app_name"
            android:scaleType="centerCrop" />

        <!-- Baner / nazwa -->
        <TextView
            android:id="@+id/appTitle"
            android:text="@string/app_name"
            android:textSize="26sp"
            android:textStyle="bold"
            android:textColor="@color/mz_text"
            android:layout_marginBottom="20dp"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content" />

        <!-- Karta logowania -->
        <LinearLayout
            android:id="@+id/loginCard"
            android:orientation="vertical"
            android:padding="20dp"
            android:background="@drawable/bg_card_soft"
            android:layout_width="match_parent"
            android:layout_height="wrap_content">

            <TextView
                android:id="@+id/loginCardTitle"
                android:text="@string/login_card_title"
                android:textColor="@color/mz_text"
                android:textSize="18sp"
                android:textStyle="bold"
                android:layout_marginBottom="12dp"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content" />

            <EditText
                android:id="@+id/editLogin"
                android:hint="@string/login_hint"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:padding="10dp"
                android:textColor="@color/mz_text"
                android:textColorHint="@color/mz_muted"
                android:background="@drawable/login_input_background" />

            <EditText
                android:id="@+id/editPass"
                android:hint="@string/login_password_hint"
                android:inputType="textPassword"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:padding="10dp"
                android:textColor="@color/mz_text"
                android:textColorHint="@color/mz_muted"
                android:background="@drawable/login_input_background" />

            <Button
                android:id="@+id/btnLogin"
                android:text="@string/login_button"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                android:backgroundTint="@color/mz_primary"
                android:textColor="@color/mz_text" />

            <TextView
                android:id="@+id/loginInfoText"
                android:text="@string/login_info_text"
                android:textSize="11sp"
                android:textColor="@color/mz_muted"
                android:layout_marginTop="12dp"
                android:layout_width="match_parent"
                android:layout_height="wrap_content" />

        </LinearLayout>

    </LinearLayout>
</ScrollView>
