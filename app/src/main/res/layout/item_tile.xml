<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:clipChildren="false"
    android:clipToPadding="false">

    <com.google.android.material.card.MaterialCardView
        android:id="@+id/cardContent"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_margin="3dp"
        android:clickable="true"
        android:focusable="true"
        android:foreground="?attr/selectableItemBackground"
        app:cardBackgroundColor="?attr/mzCardSoft"
        app:cardCornerRadius="8dp"
        app:cardElevation="0dp"
        app:strokeColor="?attr/mzBorderSoft"
        app:strokeWidth="1dp">

        <LinearLayout
            android:id="@+id/contentContainer"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:gravity="start|top"
            android:orientation="vertical"
            android:padding="15dp">

            <FrameLayout
                android:id="@+id/iconSurface"
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:layout_marginBottom="10dp"
                android:background="@drawable/bg_tile_icon_surface">

                <ImageView
                    android:id="@+id/iconView"
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:layout_gravity="center"
                    android:contentDescription="@null"
                    android:importantForAccessibility="no"
                    android:src="@drawable/ic_zut_logo_inapp"
                    app:tint="?attr/mzPrimary" />
            </FrameLayout>

            <TextView
                android:id="@+id/textTitle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:ellipsize="end"
                android:fontFamily="sans-serif-medium"
                android:includeFontPadding="false"
                android:maxLines="3"
                android:textColor="?attr/mzText"
                android:textSize="16sp"
                tools:text="Plan zajęć" />

            <TextView
                android:id="@+id/textDesc"
                style="@style/TextAppearance.ZUTnik.Label"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="5dp"
                android:ellipsize="end"
                android:includeFontPadding="false"
                android:maxLines="2"
                tools:text="Dzień, tydzień i miesiąc" />
        </LinearLayout>

        <View
            android:id="@+id/editBorder"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="@drawable/bg_tile_edit_border"
            android:visibility="gone" />
    </com.google.android.material.card.MaterialCardView>

    <ImageView
        android:id="@+id/btnDrag"
        android:layout_width="40dp"
        android:layout_height="40dp"
        android:layout_gravity="top|start"
        android:background="@drawable/bg_tile_control"
        android:clickable="true"
        android:contentDescription="@string/home_tile_move"
        android:elevation="6dp"
        android:focusable="true"
        android:padding="10dp"
        android:src="@drawable/ic_drag_handle"
        android:visibility="gone"
        app:tint="?attr/mzPrimary" />

    <ImageView
        android:id="@+id/btnDelete"
        android:layout_width="40dp"
        android:layout_height="40dp"
        android:layout_gravity="top|end"
        android:background="@drawable/bg_tile_control"
        android:contentDescription="@string/home_tile_delete"
        android:elevation="6dp"
        android:padding="11dp"
        android:src="@drawable/ic_close"
        android:visibility="gone"
        app:tint="?attr/mzDanger" />

    <TextView
        android:id="@+id/textTileSize"
        android:layout_width="wrap_content"
        android:layout_height="24dp"
        android:layout_gravity="bottom|start"
        android:layout_margin="8dp"
        android:background="@drawable/bg_tile_size_badge"
        android:fontFamily="sans-serif-medium"
        android:gravity="center"
        android:minWidth="46dp"
        android:paddingStart="8dp"
        android:paddingEnd="8dp"
        android:textColor="?attr/mzMuted"
        android:textSize="11sp"
        android:visibility="gone"
        tools:text="2 × 2" />

    <ImageView
        android:id="@+id/btnResize"
        android:layout_width="40dp"
        android:layout_height="40dp"
        android:layout_gravity="bottom|end"
        android:background="@drawable/bg_tile_control"
        android:clickable="true"
        android:contentDescription="@string/home_tile_resize"
        android:elevation="6dp"
        android:focusable="true"
        android:padding="10dp"
        android:src="@drawable/ic_resize_diagonal"
        android:visibility="gone"
        app:tint="?attr/mzPrimary" />
</FrameLayout>
