<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/easterRoot"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_easter_egg_backdrop"
    android:clickable="true"
    android:focusable="true">

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:clipToPadding="false"
        android:fillViewport="true"
        android:overScrollMode="never">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:minHeight="560dp"
            android:orientation="vertical"
            android:paddingHorizontal="16dp"
            android:paddingVertical="56dp">

            <com.google.android.material.card.MaterialCardView
                android:id="@+id/easterRewardCard"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:clickable="true"
                android:focusable="true"
                app:cardBackgroundColor="#151A1F"
                app:cardCornerRadius="8dp"
                app:cardElevation="12dp"
                app:strokeColor="#3A444C"
                app:strokeWidth="1dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center_horizontal"
                    android:orientation="vertical"
                    android:padding="24dp">

                    <View
                        android:id="@+id/easterAccentLine"
                        android:layout_width="48dp"
                        android:layout_height="3dp"
                        android:layout_marginBottom="22dp"
                        android:background="#3BC7B8" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:background="@drawable/bg_easter_reward_label"
                        android:fontFamily="sans-serif-medium"
                        android:paddingHorizontal="10dp"
                        android:paddingVertical="5dp"
                        android:text="@string/easter_achievement_label"
                        android:textColor="#7DE0D4"
                        android:textSize="11sp" />

                    <ImageView
                        android:id="@+id/easterCenterLogo"
                        android:layout_width="88dp"
                        android:layout_height="88dp"
                        android:layout_marginTop="24dp"
                        android:background="@drawable/bg_easter_egg_logo_core"
                        android:contentDescription="@string/about_logo_desc"
                        android:padding="13dp"
                        android:src="@drawable/ic_zut_logo_inapp" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="22dp"
                        android:fontFamily="sans-serif-black"
                        android:gravity="center"
                        android:text="@string/easter_reward_title"
                        android:textColor="#F5F7F8"
                        android:textSize="26sp" />

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:gravity="center"
                        android:lineSpacingExtra="2dp"
                        android:text="@string/easter_reward_message"
                        android:textColor="#AAB5BE"
                        android:textSize="14sp" />

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:layout_marginTop="24dp"
                        android:layout_marginBottom="18dp"
                        android:background="#303940" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:baselineAligned="false"
                        android:orientation="horizontal">

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:fontFamily="sans-serif-medium"
                                android:text="@string/easter_discovered_label"
                                android:textColor="#7F8B94"
                                android:textSize="10sp" />

                            <TextView
                                android:id="@+id/easterDiscoveryDate"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="4dp"
                                android:fontFamily="sans-serif-bold"
                                android:textColor="#E6EAEC"
                                android:textSize="14sp" />
                        </LinearLayout>

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:gravity="end"
                            android:orientation="vertical">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:fontFamily="sans-serif-medium"
                                android:text="@string/easter_identifier_label"
                                android:textColor="#7F8B94"
                                android:textSize="10sp" />

                            <TextView
                                android:id="@+id/easterDiscoveryCode"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="4dp"
                                android:background="@drawable/bg_easter_reward_code"
                                android:fontFamily="monospace"
                                android:paddingHorizontal="8dp"
                                android:paddingVertical="4dp"
                                android:textColor="#E6EAEC"
                                android:textSize="13sp"
                                android:textStyle="bold" />
                        </LinearLayout>
                    </LinearLayout>

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="22dp"
                        android:background="@drawable/bg_easter_reward_status"
                        android:drawablePadding="9dp"
                        android:fontFamily="sans-serif-medium"
                        android:gravity="center_vertical"
                        android:paddingHorizontal="12dp"
                        android:paddingVertical="10dp"
                        android:text="@string/easter_saved_message"
                        android:textColor="#E1C27B"
                        android:textSize="12sp"
                        app:drawableStartCompat="@drawable/ic_check"
                        app:drawableTint="#D2A54A" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/easterDoneButton"
                        android:layout_width="match_parent"
                        android:layout_height="48dp"
                        android:layout_marginTop="18dp"
                        android:backgroundTint="#3BC7B8"
                        android:fontFamily="sans-serif-bold"
                        android:insetTop="0dp"
                        android:insetBottom="0dp"
                        android:text="@string/easter_done_action"
                        android:textAllCaps="false"
                        android:textColor="#081412"
                        app:cornerRadius="8dp" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>
        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

    <androidx.appcompat.widget.AppCompatImageButton
        android:id="@+id/easterCloseButton"
        android:layout_width="40dp"
        android:layout_height="40dp"
        android:layout_gravity="top|end"
        android:layout_marginTop="18dp"
        android:layout_marginEnd="18dp"
        android:background="@drawable/bg_easter_egg_icon_button"
        android:contentDescription="@string/common_close"
        android:padding="9dp"
        android:src="@drawable/ic_close"
        app:tint="@android:color/white" />

</FrameLayout>
