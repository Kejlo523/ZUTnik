<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="?attr/mzCardSoft"
    android:paddingStart="20dp"
    android:paddingEnd="20dp"
    android:paddingTop="16dp"
    android:paddingBottom="16dp">

    <TextView
        android:id="@+id/watchProgressTitle"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/wear_sync_request_title"
        android:textSize="14sp"
        android:textStyle="bold"
        android:textColor="?attr/mzText" />

    <TextView
        android:id="@+id/watchProgressStatus"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="6dp"
        android:text="@string/nav_watch_searching"
        android:textSize="13sp"
        android:textColor="?attr/mzText" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="10dp"
        android:orientation="horizontal"
        android:gravity="center_vertical">

        <ProgressBar
            android:id="@+id/watchProgressBar"
            style="?android:attr/progressBarStyleHorizontal"
            android:layout_width="0dp"
            android:layout_height="10dp"
            android:layout_weight="1"
            android:max="100"
            android:progress="0"
            android:progressTint="?attr/mzAccent"
            android:progressBackgroundTint="?attr/mzBorderSoft" />

        <TextView
            android:id="@+id/watchProgressText"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="12dp"
            android:text="0%"
            android:textSize="12sp"
            android:textColor="?attr/mzText" />
    </LinearLayout>

    <com.google.android.material.button.MaterialButton
        android:id="@+id/watchProgressOk"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:text="@string/common_ok"
        android:visibility="gone" />
</LinearLayout>
