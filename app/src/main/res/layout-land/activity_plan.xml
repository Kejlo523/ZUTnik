<?xml version="1.0" encoding="utf-8"?>
<androidx.drawerlayout.widget.DrawerLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/drawerLayout"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_app"
    android:fitsSystemWindows="true"
    app:statusBarBackground="?attr/mzBg">

    <LinearLayout
        android:id="@+id/drawerContentRoot"
        android:orientation="vertical"
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <androidx.appcompat.widget.Toolbar
            android:id="@+id/toolbar"
            android:layout_width="match_parent"
            android:layout_height="?attr/actionBarSize"
            android:background="@drawable/bg_toolbar"
            android:elevation="0dp"
            android:titleTextColor="?attr/mzText" />

        <LinearLayout
            android:orientation="horizontal"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:baselineAligned="false">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="0.25"
                android:orientation="vertical"
                android:padding="16dp"
                android:background="?attr/mzBg">

                <TextView
                    android:id="@+id/tvHeaderLabel"
                    android:text="-"
                    android:textSize="24sp"
                    android:textStyle="bold"
                    android:textColor="?attr/mzText"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="24dp" />

                <TextView
                    android:text="Widok"
                    android:textColor="?attr/mzMuted"
                    android:textSize="12sp"
                    android:textStyle="bold"
                    android:layout_marginBottom="8dp"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content" />

                <LinearLayout
                    android:id="@+id/layoutViewModesRow"
                    android:orientation="vertical"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="@drawable/bg_card_soft"
                    android:padding="4dp"
                    android:layout_marginBottom="24dp">

                    <androidx.appcompat.widget.AppCompatButton
                        android:id="@+id/btnViewDay"
                        android:text="@string/plan_view_day"
                        android:textSize="13sp"
                        android:textStyle="bold"
                        android:layout_width="match_parent"
                        android:layout_height="48dp"
                        android:layout_marginBottom="4dp"
                        android:textAllCaps="false"
                        android:stateListAnimator="@null"
                        android:elevation="0dp"
                        android:background="@drawable/selector_mode_bg"
                        app:backgroundTint="@null"
                        android:textColor="@color/selector_mode_text" />

                    <androidx.appcompat.widget.AppCompatButton
                        android:id="@+id/btnViewWeek"
                        android:text="@string/plan_view_week"
                        android:textSize="13sp"
                        android:textStyle="bold"
                        android:layout_width="match_parent"
                        android:layout_height="48dp"
                        android:layout_marginBottom="4dp"
                        android:textAllCaps="false"
                        android:stateListAnimator="@null"
                        android:elevation="0dp"
                        android:background="@drawable/selector_mode_bg"
                        app:backgroundTint="@null"
                        android:textColor="@color/selector_mode_text" />

                    <androidx.appcompat.widget.AppCompatButton
                        android:id="@+id/btnViewMonth"
                        android:text="@string/plan_view_month"
                        android:textSize="13sp"
                        android:textStyle="bold"
                        android:layout_width="match_parent"
                        android:layout_height="48dp"
                        android:textAllCaps="false"
                        android:stateListAnimator="@null"
                        android:elevation="0dp"
                        android:background="@drawable/selector_mode_bg"
                        app:backgroundTint="@null"
                        android:textColor="@color/selector_mode_text" />
                </LinearLayout>

                <TextView
                    android:text="Akcje"
                    android:textColor="?attr/mzMuted"
                    android:textSize="12sp"
                    android:textStyle="bold"
                    android:layout_marginBottom="8dp"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">

                    <ImageButton
                        android:id="@+id/btnSearch"
                        android:layout_width="0dp"
                        android:layout_height="48dp"
                        android:layout_weight="1"
                        android:background="@drawable/bg_card_soft"
                        android:src="@drawable/ic_search"
                        app:tint="?attr/mzText"
                        android:layout_marginEnd="6dp" />

                    <ImageButton
                        android:id="@+id/btnRefresh"
                        android:layout_width="0dp"
                        android:layout_height="48dp"
                        android:layout_weight="1"
                        android:background="@drawable/bg_card_soft"
                        android:src="@drawable/ic_refresh"
                        app:tint="?attr/mzText"
                        android:layout_marginEnd="6dp" />

                    <ImageButton
                        android:id="@+id/btnMenu"
                        android:layout_width="0dp"
                        android:layout_height="48dp"
                        android:layout_weight="1"
                        android:background="@drawable/bg_card_soft"
                        android:src="@drawable/ic_more_vert"
                        app:tint="?attr/mzText" />
                </LinearLayout>

            </LinearLayout>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="0.75"
                android:paddingEnd="16dp"
                android:paddingBottom="16dp"
                android:paddingTop="8dp">

                <androidx.cardview.widget.CardView
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    app:cardBackgroundColor="?attr/mzBg"
                    app:cardCornerRadius="16dp"
                    app:cardElevation="4dp">

                    <LinearLayout
                        android:id="@+id/planContentRoot"
                        android:orientation="vertical"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent">

                        <LinearLayout
                            android:id="@+id/layoutWeekHeadersFixed"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:visibility="gone"
                            android:background="?attr/mzBgSoft"
                            android:paddingTop="12dp"
                            android:paddingBottom="12dp">
                            <View android:layout_width="40dp" android:layout_height="match_parent" />
                            <LinearLayout
                                android:id="@+id/layoutWeekHeadersRow"
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:orientation="horizontal" />
                        </LinearLayout>

                        <LinearLayout
                            android:id="@+id/layoutMonthHeadersFixed"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:visibility="gone"
                            android:background="?attr/mzBgSoft"
                            android:paddingTop="12dp"
                            android:paddingBottom="12dp" />

                        <ScrollView
                            android:id="@+id/scrollPlan"
                            android:layout_width="match_parent"
                            android:layout_height="0dp"
                            android:layout_weight="1"
                            android:fillViewport="true"
                            android:scrollbars="vertical">

                            <LinearLayout
                                android:id="@+id/planScrollContent"
                                android:orientation="vertical"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content">

                                <LinearLayout
                                    android:id="@+id/layoutPlanRoot"
                                    android:orientation="horizontal"
                                    android:layout_width="match_parent"
                                    android:layout_height="wrap_content"
                                    android:background="?attr/mzBg">

                                    <LinearLayout
                                        android:id="@+id/layoutTimeColumn"
                                        android:orientation="vertical"
                                        android:layout_width="40dp"
                                        android:layout_height="wrap_content"
                                        android:paddingEnd="6dp"
                                        android:gravity="end" />

                                    <androidx.viewpager2.widget.ViewPager2
                                        android:id="@+id/planViewPager"
                                        android:layout_width="0dp"
                                        android:layout_height="wrap_content"
                                        android:layout_weight="1"
                                        android:overScrollMode="never" />
                                </LinearLayout>
                            </LinearLayout>
                        </ScrollView>

                        <ProgressBar
                            android:id="@+id/planProgress"
                            style="?android:attr/progressBarStyleLarge"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_gravity="center"
                            android:visibility="gone"
                            android:indeterminate="true" />

                        <TextView
                            android:id="@+id/tvEmpty"
                            android:text="@string/plan_no_classes_in_range"
                            android:textColor="?attr/mzMuted"
                            android:textSize="14sp"
                            android:gravity="center"
                            android:visibility="gone"
                            android:layout_width="match_parent"
                            android:layout_height="match_parent" />
                    </LinearLayout>
                </androidx.cardview.widget.CardView>
            </LinearLayout>
        </LinearLayout>
    </LinearLayout>

    <com.google.android.material.navigation.NavigationView
        android:id="@+id/navigationView"
        android:layout_width="wrap_content"
        android:layout_height="match_parent"
        android:layout_gravity="start"
        android:background="?attr/mzBg"
        android:fitsSystemWindows="true">
        <include layout="@layout/nav_header" />
    </com.google.android.material.navigation.NavigationView>

</androidx.drawerlayout.widget.DrawerLayout>