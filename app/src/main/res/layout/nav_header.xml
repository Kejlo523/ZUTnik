<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/navHeaderRoot"
    android:orientation="vertical"
    android:paddingStart="16dp"
    android:paddingEnd="16dp"
    android:paddingTop="28dp"
    android:paddingBottom="20dp"
    android:background="@color/mz_bg"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <!-- BLOK GÓRNY: tytuł + użytkownik + linki (zajmuje całą resztę miejsca) -->
    <LinearLayout
        android:id="@+id/navTopBlock"
        android:orientation="vertical"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <ImageView
            android:id="@+id/navHeaderIcon"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:src="@mipmap/ic_zut_logo_round"
            android:scaleType="centerCrop"
            android:layout_marginEnd="10dp"
            android:clipToOutline="true" />

        <!-- GÓRA: tytuł + użytkownik -->
        <LinearLayout
            android:orientation="vertical"
            android:layout_width="match_parent"
            android:layout_height="wrap_content">

            <TextView
                android:id="@+id/navHeaderTitle"
                android:text="mZUT v2"
                android:textSize="20sp"
                android:textStyle="bold"
                android:fontFamily="sans-serif-medium"
                android:textColor="@color/mz_text"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content" />

            <TextView
                android:id="@+id/navHeaderUser"
                android:text="Student"
                android:textSize="12sp"
                android:fontFamily="sans-serif"
                android:textColor="@color/mz_muted"
                android:layout_marginTop="2dp"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content" />
        </LinearLayout>

        <!-- separator nad linkami -->
        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:layout_marginTop="16dp"
            android:background="@color/mz_border_soft" />

        <!-- LINKI -->
        <LinearLayout
            android:orientation="vertical"
            android:layout_marginTop="12dp"
            android:layout_width="match_parent"
            android:layout_height="wrap_content">

            <TextView
                android:id="@+id/navLinkHome"
                android:text="Pulpit główny"
                android:textSize="14sp"
                android:fontFamily="sans-serif-medium"
                android:textColor="@color/mz_text"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:paddingTop="10dp"
                android:paddingBottom="10dp"
                android:layout_marginTop="4dp"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_nav_item"
                android:gravity="center_vertical"
                android:clickable="true"
                android:focusable="true"
                android:foreground="?attr/selectableItemBackground" />

            <TextView
                android:id="@+id/navLinkPlan"
                android:text="Plan zajęć"
                android:textSize="14sp"
                android:fontFamily="sans-serif-medium"
                android:textColor="@color/mz_text"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:paddingTop="10dp"
                android:paddingBottom="10dp"
                android:layout_marginTop="6dp"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_nav_item"
                android:gravity="center_vertical"
                android:clickable="true"
                android:focusable="true"
                android:foreground="?attr/selectableItemBackground" />

            <TextView
                android:id="@+id/navLinkGrades"
                android:text="Oceny"
                android:textSize="14sp"
                android:fontFamily="sans-serif-medium"
                android:textColor="@color/mz_text"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:paddingTop="10dp"
                android:paddingBottom="10dp"
                android:layout_marginTop="6dp"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_nav_item"
                android:gravity="center_vertical"
                android:clickable="true"
                android:focusable="true"
                android:foreground="?attr/selectableItemBackground" />

            <TextView
                android:id="@+id/navLinkInfo"
                android:text="Dane Studenta"
                android:textSize="14sp"
                android:fontFamily="sans-serif-medium"
                android:textColor="@color/mz_text"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:paddingTop="10dp"
                android:paddingBottom="10dp"
                android:layout_marginTop="6dp"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_nav_item"
                android:gravity="center_vertical"
                android:clickable="true"
                android:focusable="true"
                android:foreground="?attr/selectableItemBackground" />

            <TextView
                android:id="@+id/navLinkNews"
                android:text="Aktualności ZUT"
                android:textSize="14sp"
                android:fontFamily="sans-serif-medium"
                android:textColor="@color/mz_text"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:paddingTop="10dp"
                android:paddingBottom="10dp"
                android:layout_marginTop="6dp"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_nav_item"
                android:gravity="center_vertical"
                android:clickable="true"
                android:focusable="true"
                android:foreground="?attr/selectableItemBackground" />

            <TextView
                android:id="@+id/navLinkAbout"
                android:text="O aplikacji"
                android:textSize="14sp"
                android:fontFamily="sans-serif-medium"
                android:textColor="@color/mz_text"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:paddingTop="10dp"
                android:paddingBottom="10dp"
                android:layout_marginTop="6dp"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_nav_item"
                android:gravity="center_vertical"
                android:clickable="true"
                android:focusable="true"
                android:foreground="?attr/selectableItemBackground" />
        </LinearLayout>
    </LinearLayout>

    <TextView
        android:id="@+id/navAppVersion"
        android:text="@string/app_version"
        android:textSize="12sp"
        android:fontFamily="sans-serif"
        android:textColor="@color/mz_muted"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:paddingTop="6dp"
        android:paddingBottom="6dp"
        android:layout_width="match_parent"
        android:layout_height="wrap_content" />

    <!-- separator nad wylogowaniem -->
    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:layout_marginBottom="8dp"
        android:background="@color/mz_border_soft" />


    <!-- DÓŁ: wyloguj – przy samym dole -->
    <TextView
        android:id="@+id/navLogout"
        android:text="Wyloguj się"
        android:textSize="14sp"
        android:fontFamily="sans-serif-medium"
        android:textColor="@color/mz_danger"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:paddingTop="10dp"
        android:paddingBottom="10dp"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:clickable="true"
        android:focusable="true"
        android:background="@drawable/bg_nav_logout"
        android:foreground="?attr/selectableItemBackground" />

</LinearLayout>