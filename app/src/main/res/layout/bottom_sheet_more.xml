<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="?attr/mzBg"
    android:orientation="vertical"
    android:paddingStart="20dp"
    android:paddingTop="8dp"
    android:paddingEnd="20dp"
    android:paddingBottom="24dp">

    <View
        android:layout_width="36dp"
        android:layout_height="4dp"
        android:layout_gravity="center_horizontal"
        android:layout_marginBottom="16dp"
        android:background="@drawable/bg_sheet_handle" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@drawable/bg_card_modern"
        android:orientation="vertical"
        android:paddingVertical="4dp">

        <TextView
            android:id="@+id/moreLinkFinance"
            style="@style/MoreSheetItem"
            android:text="@string/finance_title" />

        <View style="@style/MoreSheetDivider" />

        <TextView
            android:id="@+id/moreLinkAttendance"
            style="@style/MoreSheetItem"
            android:text="@string/attendance_title" />

        <View style="@style/MoreSheetDivider" />

        <TextView
            android:id="@+id/moreLinkNews"
            style="@style/MoreSheetItem"
            android:text="@string/news_title" />

        <View style="@style/MoreSheetDivider" />

        <TextView
            android:id="@+id/moreLinkUseful"
            style="@style/MoreSheetItem"
            android:text="@string/nav_useful_links" />

        <View style="@style/MoreSheetDivider" />

        <TextView
            android:id="@+id/moreLinkAbout"
            style="@style/MoreSheetItem"
            android:text="@string/about_title" />
    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:background="@drawable/bg_card_modern"
        android:orientation="vertical"
        android:paddingVertical="4dp">

        <TextView
            android:id="@+id/moreLinkSettings"
            style="@style/MoreSheetItem"
            android:text="@string/nav_settings_label" />

        <View style="@style/MoreSheetDivider" />

        <TextView
            android:id="@+id/moreLinkLogout"
            style="@style/MoreSheetItem"
            android:drawablePadding="12dp"
            android:text="@string/nav_logout_label"
            android:textColor="?attr/mzDanger"
            app:drawableStartCompat="@drawable/ic_logout_24"
            app:drawableTint="?attr/mzDanger" />
    </LinearLayout>

    <TextView
        android:id="@+id/moreAppVersion"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="20dp"
        android:layout_marginBottom="8dp"
        android:gravity="center"
        android:textColor="?attr/mzMuted"
        android:textSize="12sp" />

</LinearLayout>
