<resources xmlns:tools="http://schemas.android.com/tools">

    <!-- Base Application Theme -->
    <style name="Base.Theme.ZUTnik" parent="Theme.MaterialComponents.DayNight.NoActionBar">
        <item name="colorPrimaryDark">?attr/mzBg</item>
        <item name="android:windowLightStatusBar">false</item>
        <item name="android:windowBackground">?attr/mzBg</item>

        <item name="android:windowLightNavigationBar" tools:targetApi="27">true</item>

        <!-- No Title -->
        <item name="windowActionBar">false</item>
        <item name="android:windowActionBar">false</item>
        <item name="windowNoTitle">true</item>

        <!-- Splash -->
        <item name="android:windowSplashScreenBackground" tools:targetApi="31">?attr/mzBg</item>
        <item name="android:windowSplashScreenAnimatedIcon" tools:targetApi="31">@mipmap/ic_zut_logo_round</item>
        <item name="android:windowSplashScreenAnimationDuration" tools:targetApi="31">200</item>
        <item name="android:windowSplashScreenIconBackgroundColor" tools:targetApi="31">@android:color/transparent</item>

        <!-- Dialogs & Popups -->
        <item name="materialAlertDialogTheme">@style/ThemeOverlay.ZUTnik.AlertDialog</item>
        <item name="popupMenuStyle">@style/Widget.ZUTnik.PopupMenu</item>
        <item name="android:popupMenuStyle">@style/Widget.ZUTnik.PopupMenu</item>

        <item name="mzNavHeader">@color/mz_nav_header</item>
        <item name="mzNavHeaderText">@color/mz_nav_header_text</item>
        <item name="toolbarStyle">@style/Widget.ZUTnik.Toolbar</item>
    </style>

    <!-- Default Theme (Light/Reference) uses colors.xml -->
    <style name="Theme.ZUTnik" parent="Base.Theme.ZUTnik">
        <item name="colorPrimary">@color/mz_primary</item>
        <item name="colorPrimaryVariant">@color/mz_primary_alt</item>
        <item name="colorOnPrimary">@android:color/white</item>

        <item name="mzBg">@color/mz_bg</item>
        <item name="mzBgSoft">@color/mz_bg_soft</item>
        <item name="mzCard">@color/mz_card</item>
        <item name="mzCardSoft">@color/mz_card_soft</item>
        <item name="mzBgSurface">@color/mz_bg_surface</item>
        <item name="mzInputBg">@color/mz_card_soft</item>
        <item name="mzText">@color/mz_text</item>
        <item name="mzMuted">@color/mz_muted</item>
        <item name="mzBorderSoft">@color/mz_border_soft</item>
        <item name="mzBorderStrong">@color/mz_border_strong</item>
        <item name="mzPrimary">@color/mz_primary</item>
        <item name="mzPrimaryAlt">@color/mz_primary_alt</item>
        <item name="mzAccent">@color/mz_accent</item>
        <item name="mzLime">@color/mz_lime</item>
        <item name="mzSuccess">@color/mz_success</item>
        <item name="mzDanger">@color/mz_danger</item>
        <item name="mzDangerSoft">@color/mz_danger_soft</item>
        <item name="mzToolbarGradStart">@color/mz_toolbar_grad_start</item>
        <item name="mzToolbarGradEnd">@color/mz_toolbar_grad_end</item>
        <item name="mzNavHeader">@color/mz_nav_header</item>
        <item name="mzNavHeaderText">@color/mz_nav_header_text</item>
        
        <item name="planWeekHeaderSelectedBg">@color/plan_week_header_selected_bg</item>
        <item name="planWeekDaySelectedBg">@color/plan_week_day_selected_bg</item>

        <!-- Plan Defaults -->
        <item name="mzPlanHourLine">@color/plan_hour_line</item>
        <item name="mzPlanNowLine">@color/plan_now_line</item>
        <item name="mzPlanColumnText">@color/plan_time_column_text</item>
        <item name="mzPlanHeaderText">@color/plan_week_header_text</item>
        <item name="mzPlanGridBg">@color/plan_week_day_bg</item>
        <item name="mzPlanGridBgSelected">@color/plan_week_day_selected_bg</item>
        <item name="mzPlanEventTextColor">@color/plan_event_text</item>
    </style>

    <!-- Deep Blue Theme (Day/Light) -->
    <style name="Theme.ZUTnik.DeepBlue" parent="Base.Theme.ZUTnik">
        <item name="colorPrimary">#1E3A8A</item> <!-- Blue 900 -->
        <item name="colorPrimaryVariant">#172554</item> <!-- Blue 950 -->
        <item name="colorOnPrimary">#FFFFFF</item>

        <!-- Overrides for Deep Blue -->
        <item name="mzBg">#F0F8FF</item> <!-- AliceBlue -->
        <item name="mzBgSoft">#E0F2FE</item> <!-- Sky 100 -->
        <item name="mzCard">#FFFFFF</item>
        <item name="mzCardSoft">#F1F5F9</item>
        <item name="mzBgSurface">#FFFFFF</item>
        <item name="mzInputBg">#DBEAFE</item>
        <item name="mzText">#1E293B</item> <!-- Slate 800 -->
        <item name="mzMuted">#64748B</item> <!-- Slate 500 -->
        <item name="mzBorderSoft">#E2E8F0</item>
        <item name="mzBorderStrong">#94A3B8</item>
        <item name="mzPrimary">#1E3A8A</item>
        <item name="mzPrimaryAlt">#1D4ED8</item>
        <item name="mzAccent">#38BDF8</item>
        <item name="mzLime">@color/mz_lime</item>
        <item name="mzSuccess">#16A34A</item>
        <item name="mzDanger">#DC2626</item>
        <item name="mzDangerSoft">#FEE2E2</item>
        <item name="mzToolbarGradStart">#FFFFFF</item>
        <item name="mzToolbarGradEnd">#F0F8FF</item>
        <item name="mzNavHeader">#172554</item>
        <item name="mzNavHeaderText">#FFFFFF</item>
        
        <item name="android:windowLightStatusBar">false</item>
        <item name="android:windowLightNavigationBar" tools:targetApi="27">true</item>

        <!-- Plan Deep Blue Overrides -->
        <item name="mzPlanHourLine">#20000000</item> 
        <item name="mzPlanNowLine">#DC2626</item> <!-- Red 600 -->
        <item name="mzPlanColumnText">#334155</item> 
        <item name="mzPlanHeaderText">#1E293B</item>
        <item name="mzPlanGridBg">@android:color/transparent</item> 
        <item name="mzPlanGridBgSelected">#201E3A8A</item> 
        <item name="mzPlanEventTextColor">#1E293B</item>
        <item name="planWeekHeaderSelectedBg">#DBEAFE</item>
        <item name="planWeekDaySelectedBg">#EFF6FF</item>
    </style>



    <!-- Lime Theme (Day/Light) -->
    <style name="Theme.ZUTnik.Lime" parent="Base.Theme.ZUTnik">
        <item name="colorPrimary">#65A30D</item>
        <item name="colorPrimaryVariant">#4D7C0F</item>
        <item name="colorOnPrimary">#FFFFFF</item>

        <item name="mzBg">#F4FFF6</item>
        <item name="mzBgSoft">#ECFDF3</item>
        <item name="mzCard">#FFFFFF</item>
        <item name="mzCardSoft">#F0FDF4</item>
        <item name="mzBgSurface">#FFFFFF</item>
        <item name="mzInputBg">#DCFCE7</item>
        <item name="mzText">#1E293B</item>
        <item name="mzMuted">#64748B</item>
        <item name="mzBorderSoft">#DCFCE7</item>
        <item name="mzBorderStrong">#A7F3D0</item>
        <item name="mzPrimary">#65A30D</item>
        <item name="mzPrimaryAlt">#4D7C0F</item>
        <item name="mzAccent">#22C55E</item>
        <item name="mzLime">@color/mz_lime</item>
        <item name="mzSuccess">#16A34A</item>
        <item name="mzDanger">#DC2626</item>
        <item name="mzDangerSoft">#FEE2E2</item>
        <item name="mzToolbarGradStart">#FFFFFF</item>
        <item name="mzToolbarGradEnd">#F4FFF6</item>
        <item name="mzNavHeader">#4D7C0F</item>
        <item name="mzNavHeaderText">#FFFFFF</item>

        <item name="android:windowLightStatusBar">false</item>
        <item name="android:windowLightNavigationBar" tools:targetApi="27">true</item>

        <!-- Plan Lime Overrides -->
        <item name="mzPlanHourLine">#1A14532D</item>
        <item name="mzPlanNowLine">#DC2626</item>
        <item name="mzPlanColumnText">#334155</item>
        <item name="mzPlanHeaderText">#1E293B</item>
        <item name="mzPlanGridBg">@android:color/transparent</item>
        <item name="mzPlanGridBgSelected">#2065A30D</item>
        <item name="mzPlanEventTextColor">#1E293B</item>
        <item name="planWeekHeaderSelectedBg">#DCFCE7</item>
        <item name="planWeekDaySelectedBg">#ECFDF3</item>
    </style>
    <!-- High Contrast Theme (Day) - Accessibility focused -->
    <style name="Theme.ZUTnik.HighContrast" parent="Base.Theme.ZUTnik">
        <item name="colorPrimary">#000000</item>
        <item name="colorPrimaryVariant">#000000</item>
        <item name="colorOnPrimary">#FFFFFF</item>

        <!-- High Contrast - Pure white bg, black text -->
        <item name="mzBg">#FFFFFF</item>
        <item name="mzBgSoft">#F5F5F5</item>
        <item name="mzCard">#FFFFFF</item>
        <item name="mzCardSoft">#EEEEEE</item>
        <item name="mzBgSurface">#FFFFFF</item>
        <item name="mzInputBg">#DDDDDD</item>
        <item name="mzText">#000000</item>
        <item name="mzMuted">#333333</item>
        <item name="mzBorderSoft">#000000</item>
        <item name="mzBorderStrong">#000000</item>
        <item name="mzPrimary">#0000EE</item>
        <item name="mzPrimaryAlt">#0000CC</item>
        <item name="mzAccent">#0000EE</item>
        <item name="mzLime">@color/mz_lime</item>
        <item name="mzSuccess">#006600</item>
        <item name="mzDanger">#CC0000</item>
        <item name="mzDangerSoft">#FFCCCC</item>
        <item name="mzToolbarGradStart">#FFFFFF</item>
        <item name="mzToolbarGradEnd">#FFFFFF</item>
        <item name="mzNavHeader">#000000</item>
        <item name="mzNavHeaderText">#FFFFFF</item>

        <item name="android:windowLightStatusBar">false</item>
        <item name="android:windowLightNavigationBar" tools:targetApi="27">true</item>

        <!-- Plan High Contrast -->
        <item name="mzPlanHourLine">#000000</item>
        <item name="mzPlanNowLine">#CC0000</item>
        <item name="mzPlanColumnText">#000000</item>
        <item name="mzPlanHeaderText">#000000</item>
        <item name="mzPlanGridBg">#FFFFFF</item>
        <item name="mzPlanGridBgSelected">#DDDDDD</item>
        <item name="mzPlanEventTextColor">#000000</item>
        <item name="planWeekHeaderSelectedBg">#CCCCCC</item>
        <item name="planWeekDaySelectedBg">#EEEEEE</item>
    </style>

    <style name="ThemeOverlay.ZUTnik.Toolbar" parent="ThemeOverlay.AppCompat.ActionBar">
        <item name="colorControlNormal">?attr/mzText</item>
        <item name="android:textColorPrimary">?attr/mzText</item>
    </style>

    <style name="Widget.ZUTnik.Toolbar" parent="Widget.AppCompat.Toolbar">
        <item name="android:background">@drawable/bg_toolbar</item>
        <item name="android:theme">@style/ThemeOverlay.ZUTnik.Toolbar</item>
        <item name="android:minHeight">?attr/actionBarSize</item>
        <item name="titleTextColor">?attr/mzText</item>
        <item name="subtitleTextColor">?attr/mzText</item>
        <item name="android:elevation">0dp</item>
    </style>

    <!-- AlertDialog Theme Overlay -->
    <style name="ThemeOverlay.ZUTnik.AlertDialog" parent="ThemeOverlay.MaterialComponents.MaterialAlertDialog">
        <item name="android:windowBackground">@drawable/bg_dialog_rounded_dark</item>
        <item name="colorSurface">?attr/mzBgSoft</item>
        <item name="colorOnSurface">?attr/mzText</item>
        <item name="materialAlertDialogTitlePanelStyle">@style/Widget.ZUTnik.AlertDialog.Title.Panel</item>
        <item name="materialAlertDialogTitleIconStyle">@style/MaterialAlertDialog.MaterialComponents.Title.Icon</item>
        <item name="materialAlertDialogTitleTextStyle">@style/TextAppearance.ZUTnik.AlertDialog.Title</item>
        <item name="materialAlertDialogBodyTextStyle">@style/TextAppearance.ZUTnik.AlertDialog.Body</item>
        <item name="android:windowAnimationStyle">@style/Animation.ZUTnik.Dialog</item>
    </style>

    <style name="ThemeOverlay.ZUTnik.AlertDialog.Dark" parent="ThemeOverlay.MaterialComponents.MaterialAlertDialog">
        <item name="android:windowBackground">@drawable/bg_dialog_rounded_dark</item>
        <item name="colorSurface">?attr/mzBgSoft</item>
        <item name="colorOnSurface">?attr/mzText</item>
        <item name="materialAlertDialogTitlePanelStyle">@style/Widget.ZUTnik.AlertDialog.Title.Panel</item>
        <item name="materialAlertDialogTitleIconStyle">@style/MaterialAlertDialog.MaterialComponents.Title.Icon</item>
        <item name="materialAlertDialogTitleTextStyle">@style/TextAppearance.ZUTnik.AlertDialog.Title</item>
        <item name="materialAlertDialogBodyTextStyle">@style/TextAppearance.ZUTnik.AlertDialog.Body</item>
        <item name="android:windowAnimationStyle">@style/Animation.ZUTnik.Dialog</item>
    </style>

    <style name="Animation.ZUTnik" parent="@android:style/Animation" />

    <style name="Animation.ZUTnik.Dialog" parent="Animation.ZUTnik">
        <item name="android:windowEnterAnimation">@anim/dialog_enter</item>
        <item name="android:windowExitAnimation">@anim/dialog_exit</item>
    </style>

    <style name="TextAppearance.ZUTnik.AlertDialog.Title" parent="MaterialAlertDialog.MaterialComponents.Title.Text">
        <item name="android:textColor">?attr/mzText</item>
    </style>

    <style name="TextAppearance.ZUTnik.AlertDialog.Body" parent="TextAppearance.MaterialComponents.Body2">
        <item name="android:textColor">?attr/mzMuted</item>
        <item name="android:textSize">14sp</item>
        <item name="android:lineSpacingExtra">2dp</item>
    </style>

    <style name="Widget.ZUTnik.AlertDialog.Title.Panel" parent="MaterialAlertDialog.MaterialComponents.Title.Panel">
        <item name="android:paddingLeft">?attr/dialogPreferredPadding</item>
        <item name="android:paddingRight">?attr/dialogPreferredPadding</item>
        <item name="android:paddingTop">@dimen/abc_dialog_padding_top_material</item>
    </style>

    <!-- Popup Menu -->
    <style name="ThemeOverlay.ZUTnik.PopupMenu" parent="ThemeOverlay.MaterialComponents">
        <item name="popupMenuStyle">@style/Widget.ZUTnik.PopupMenu</item>
        <item name="android:popupMenuStyle">@style/Widget.ZUTnik.PopupMenu</item>
    </style>

    <style name="Widget.ZUTnik.PopupMenu" parent="Widget.MaterialComponents.PopupMenu">
        <item name="android:popupBackground">@drawable/bg_popup_menu</item>
        <item name="android:textColor">?attr/mzText</item>
        <item name="android:itemTextAppearance">@style/TextAppearance.ZUTnik.PopupMenu</item>
    </style>

    <style name="TextAppearance.ZUTnik.PopupMenu" parent="TextAppearance.MaterialComponents.Body2">
        <item name="android:textColor">?attr/mzText</item>
    </style>

    <style name="ThemeOverlay.ZUTnik.BottomSheetDialog" parent="ThemeOverlay.MaterialComponents.BottomSheetDialog">
        <item name="bottomSheetStyle">@style/Widget.ZUTnik.BottomSheet.Modal</item>
    </style>

    <style name="Widget.ZUTnik.BottomSheet.Modal" parent="Widget.Design.BottomSheet.Modal">
        <item name="android:background">@null</item>
        <item name="backgroundTint">@null</item>
        <item name="shapeAppearance">@null</item>
        <item name="shapeAppearanceOverlay">@null</item>
        <item name="enforceMaterialTheme">false</item>
    </style>

    <style name="MoreSheetItem">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:background">?attr/selectableItemBackground</item>
        <item name="android:clickable">true</item>
        <item name="android:focusable">true</item>
        <item name="android:paddingStart">20dp</item>
        <item name="android:paddingTop">16dp</item>
        <item name="android:paddingEnd">20dp</item>
        <item name="android:paddingBottom">16dp</item>
        <item name="android:textColor">?attr/mzText</item>
        <item name="android:textSize">16sp</item>
    </style>

    <style name="MoreSheetDivider">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">1dp</item>
        <item name="android:layout_marginStart">20dp</item>
        <item name="android:background">?attr/mzBorderSoft</item>
    </style>

    <style name="MoreSheetRow">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">56dp</item>
        <item name="android:orientation">horizontal</item>
        <item name="android:gravity">center_vertical</item>
        <item name="android:clickable">true</item>
        <item name="android:focusable">true</item>
        <item name="android:foreground">?attr/selectableItemBackground</item>
        <item name="android:paddingStart">14dp</item>
        <item name="android:paddingEnd">12dp</item>
    </style>

    <style name="MoreSheetIconFrame">
        <item name="android:layout_width">34dp</item>
        <item name="android:layout_height">34dp</item>
        <item name="android:layout_marginEnd">12dp</item>
        <item name="android:background">@drawable/bg_circle_soft</item>
        <item name="android:padding">7dp</item>
    </style>

    <style name="MoreSheetDangerIconFrame" parent="MoreSheetIconFrame">
        <item name="android:background">@drawable/bg_nav_logout</item>
    </style>

    <style name="MoreSheetIcon">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">match_parent</item>
        <item name="android:tint">?attr/mzMuted</item>
        <item name="android:contentDescription">@null</item>
        <item name="android:importantForAccessibility">no</item>
    </style>

    <style name="MoreSheetDangerIcon" parent="MoreSheetIcon">
        <item name="android:tint">?attr/mzDanger</item>
    </style>

    <style name="MoreSheetLabel">
        <item name="android:layout_width">0dp</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:layout_weight">1</item>
        <item name="android:ellipsize">end</item>
        <item name="android:maxLines">1</item>
        <item name="android:textColor">?attr/mzText</item>
        <item name="android:textSize">15sp</item>
        <item name="android:textStyle">bold</item>
    </style>

    <style name="MoreSheetDangerLabel" parent="MoreSheetLabel">
        <item name="android:textColor">?attr/mzDanger</item>
    </style>

    <style name="MoreSheetChevron">
        <item name="android:layout_width">18dp</item>
        <item name="android:layout_height">18dp</item>
        <item name="android:alpha">0.54</item>
        <item name="android:tint">?attr/mzMuted</item>
        <item name="android:contentDescription">@null</item>
        <item name="android:importantForAccessibility">no</item>
    </style>

</resources>
