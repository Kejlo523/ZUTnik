<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/mainShellRoot"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="?attr/mzBg"
    android:fitsSystemWindows="false"
    android:orientation="vertical">

    <FrameLayout
        android:id="@+id/drawerContentRoot"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical">

            <androidx.appcompat.widget.Toolbar
                android:id="@+id/toolbar"
                android:layout_width="match_parent"
                android:layout_height="?attr/actionBarSize"
                android:background="@drawable/bg_toolbar"
                android:elevation="0dp"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:titleTextColor="?attr/mzNavHeaderText" />

            <ScrollView
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="1"
                android:clipToPadding="false"
                android:fillViewport="true"
                android:overScrollMode="ifContentScrolls"
                android:scrollbars="none">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:paddingStart="16dp"
                    android:paddingTop="12dp"
                    android:paddingEnd="16dp"
                    android:paddingBottom="20dp">

                    <LinearLayout
                        android:id="@+id/homeHero"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="20dp"
                        android:background="@drawable/bg_card_modern"
                        android:gravity="center_vertical"
                        android:orientation="horizontal"
                        android:padding="18dp">

                        <ImageView
                            android:layout_width="52dp"
                            android:layout_height="52dp"
                            android:contentDescription="@string/app_name"
                            android:src="@drawable/ic_zut_logo_inapp" />

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="14dp"
                            android:layout_weight="1"
                            android:orientation="vertical">

                            <TextView
                                android:id="@+id/textWelcome"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:text="@string/home_welcome_fallback"
                                android:textColor="?attr/mzText"
                                android:textSize="22sp"
                                android:textStyle="bold" />

                            <TextView
                                android:id="@+id/textWelcomeSub"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="4dp"
                                android:text="@string/home_welcome_subtitle"
                                android:textColor="?attr/mzMuted"
                                android:textSize="13sp"
                                android:lineSpacingExtra="2dp" />
                        </LinearLayout>
                    </LinearLayout>

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="12dp"
                        android:letterSpacing="0"
                        android:text="@string/home_shortcuts_title"
                        android:textColor="?attr/mzText"
                        android:textSize="20sp"
                        android:textStyle="bold" />

                    <pl.kejlo.zutnik.TileGridLayout
                        android:id="@+id/tileGrid"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="16dp" />

                    <LinearLayout
                        android:id="@+id/homeSection"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:background="@drawable/bg_card_modern"
                        android:orientation="vertical"
                        android:padding="16dp">

                        <TextView
                            android:id="@+id/textFooterMeta"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:gravity="start"
                            android:lineSpacingExtra="3dp"
                            android:text="@string/home_footer_meta"
                            android:textColor="?attr/mzMuted"
                            android:textSize="12sp" />
                    </LinearLayout>

                </LinearLayout>
            </ScrollView>
        </LinearLayout>

        <androidx.cardview.widget.CardView
            android:id="@+id/indicatorOverlay"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:layout_gravity="bottom|start"
            android:layout_margin="24dp"
            android:visibility="gone"
            app:cardBackgroundColor="?attr/mzPrimary"
            app:cardCornerRadius="24dp"
            app:cardElevation="6dp">

            <ImageView
                android:id="@+id/indicatorIcon"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:layout_gravity="center"
                android:src="@drawable/ic_check"
                app:tint="?attr/colorOnPrimary" />
        </androidx.cardview.widget.CardView>

    </FrameLayout>

    <include layout="@layout/include_bottom_navigation" />
</LinearLayout>
