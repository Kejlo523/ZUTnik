<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="12dp"
    android:clickable="true"
    android:focusable="true"
    android:foreground="?attr/selectableItemBackground"
    app:cardBackgroundColor="?attr/mzBgSurface"
    app:cardCornerRadius="16dp"
    app:cardElevation="2dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- Image Container -->
        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="140dp">

            <ImageView
                android:id="@+id/linkImage"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:scaleType="centerCrop"
                android:src="@drawable/bg_header_gradient"
                android:contentDescription="@null" />

            <!-- Gradient overlay for text readability if text were over image, 
                 but here we just add a subtle scrim for better look -->
            <View
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:background="#15000000" />
            
            <ProgressBar
                android:id="@+id/linkImageLoading"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:layout_gravity="center"
                android:indeterminateTint="?attr/mzAccent"
                android:visibility="gone" />

            <!-- Badge for "Highlighted" links -->
            <TextView
                android:id="@+id/linkBadge"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="top|end"
                android:layout_margin="8dp"
                android:background="@drawable/bg_accent_rounded"
                android:fontFamily="sans-serif-medium"
                android:paddingLeft="8dp"
                android:paddingTop="4dp"
                android:paddingRight="8dp"
                android:paddingBottom="4dp"
                android:text="@string/useful_links_badge_recommended"
                android:textColor="#FFFFFF"
                android:textSize="11sp"
                android:visibility="gone" />
        </FrameLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <!-- Domain / Source (small top label) -->
            <TextView
                android:id="@+id/linkUrl"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginBottom="4dp"
                android:fontFamily="sans-serif-medium"
                tools:text="zut.edu.pl"
                android:textAllCaps="true"
                android:textColor="?attr/mzMuted"
                android:textSize="11sp"
                android:letterSpacing="0.05"/>

            <!-- Title -->
            <TextView
                android:id="@+id/linkTitle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="6dp"
                android:fontFamily="sans-serif-black"
                tools:text="Tytuł strony"
                android:textColor="?attr/mzText"
                android:textSize="16sp"
                android:textStyle="bold" />

            <!-- Description -->
            <TextView
                android:id="@+id/linkDesc"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:ellipsize="end"
                android:fontFamily="sans-serif"
                android:maxLines="3"
                tools:text="Opis strony..."
                android:textColor="?attr/mzMuted"
                android:textSize="13sp"
                android:lineSpacingExtra="2dp"/>

        </LinearLayout>

    </LinearLayout>

</androidx.cardview.widget.CardView>
