<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/widgetRoot"
    android:orientation="vertical"
    android:background="@drawable/bg_card_soft"
    android:padding="8dp"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <!-- GÓRA: Data + refresh -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical">

        <TextView
            android:id="@+id/widgetDate"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Dziś"
            android:textStyle="bold"
            android:textSize="15sp"
            android:textColor="@color/mz_text" />

        <ImageView
            android:id="@+id/widgetRefresh"
            android:layout_width="20dp"
            android:layout_height="20dp"
            android:src="@android:drawable/ic_popup_sync"
            android:tint="@color/mz_muted"
            android:padding="2dp" />
    </LinearLayout>

    <!-- Podtytuł -->
    <TextView
        android:id="@+id/widgetSubtitle"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Dzisiejsze zajęcia"
        android:textSize="12sp"
        android:textColor="@color/mz_muted"
        android:layout_marginTop="2dp"
        android:layout_marginBottom="4dp" />

    <!-- Lista zajęć -->
    <ListView
        android:id="@+id/widgetList"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:divider="@android:color/transparent"
        android:dividerHeight="2dp"
        android:paddingTop="0dp"
        android:paddingBottom="0dp" />

</LinearLayout>
