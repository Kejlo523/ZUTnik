<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:card_view="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginStart="0dp"
    android:layout_marginEnd="0dp"
    android:layout_marginTop="4dp"
    android:layout_marginBottom="4dp"
    card_view:cardCornerRadius="0dp"
    card_view:cardUseCompatPadding="false"
    card_view:cardElevation="0dp"
    card_view:cardBackgroundColor="@android:color/transparent">

    <LinearLayout
        android:id="@+id/itemRoot"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="14dp"
        android:background="@drawable/bg_card_soft"
        android:clickable="false"
        android:focusable="true" >

        <!-- Tytuł linku -->
        <TextView
            android:id="@+id/linkTitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Tytuł linku"
            android:textStyle="bold"
            android:textSize="15sp"
            android:fontFamily="sans-serif-medium"
            android:textColor="@color/mz_text" />

        <!-- Opis linku -->
        <TextView
            android:id="@+id/linkDesc"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:text="Krótki opis do czego służy ten link."
            android:textSize="13sp"
            android:textColor="@color/mz_muted" />

        <!-- Adres URL -->
        <TextView
            android:id="@+id/linkUrl"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:text="https://www.zut.edu.pl"
            android:textSize="12sp"
            android:textColor="#60A5FA" />

        <!-- Badge "Twój kierunek / wydział" -->
        <TextView
            android:id="@+id/linkBadge"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:paddingStart="8dp"
            android:paddingEnd="8dp"
            android:paddingTop="4dp"
            android:paddingBottom="4dp"
            android:text="Twój kierunek"
            android:textSize="11sp"
            android:textColor="@color/mz_text"
            android:background="@drawable/bg_card_primary"
            android:visibility="gone" />

    </LinearLayout>

</androidx.cardview.widget.CardView>
